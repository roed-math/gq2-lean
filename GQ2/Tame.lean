/-!
# Lemma 3.1 ‚Äî structure of finite tame quotients

Paper Lemma 3.1: *In every finite quotient generated by `s, t` with `t^s = t^2`, the element
`t` has odd order, and the quotient has the form `C_e ‚ãä C_n` (`e` odd) with `s‚Åª¬π t s = t^2`.
Every normal 2-subgroup of such a quotient is central and lies in the unramified cyclic
direction.*

Here the paper's `t^s = t^2` means `s‚Åª¬π * t * s = t^2` (right-conjugation convention).

The first assertion ‚Äî `t` has odd order ‚Äî is elementary and is **proved in full** below.
The further claims used by the formalization ‚Äî normality of `‚ü®t‚ü©` and centrality of normal
2-subgroups ‚Äî are also proved below.  The explicit `C_e ‚ãä C_n` decomposition is not separately
packaged because no downstream theorem consumes it.
-/

namespace GQ2.Tame

open scoped Classical

variable {G : Type*} [Group G]

/-- Iterated conjugation: `(s‚Åø)‚Åª¬π t s‚Åø = t^(2‚Åø)`, from the tame relation `s‚Åª¬π t s = t¬≤`. -/
theorem conj_pow_iterate {s t : G} (h : s‚Åª¬π * t * s = t ^ 2) :
    ‚àÄ n : ‚Ñï, (s ^ n)‚Åª¬π * t * s ^ n = t ^ (2 ^ n) := by
  intro n
  induction n with
  | zero => simp
  | succ k ih =>
    have step : (s ^ (k + 1))‚Åª¬π * t * s ^ (k + 1)
        = (s ^ k)‚Åª¬π * (s‚Åª¬π * t * s) * s ^ k := by
      group
    rw [step, h]
    have conj_sq : (s ^ k)‚Åª¬π * t ^ 2 * s ^ k = ((s ^ k)‚Åª¬π * t * s ^ k) ^ 2 := by
      rw [pow_two, pow_two]; group
    rw [conj_sq, ih, ‚Üê pow_mul, ‚Üê pow_succ]

/-- **Lemma 3.1 (first assertion).** If a finite group is generated by `s, t` with the tame
relation `s‚Åª¬π t s = t¬≤` (so in particular `s` has finite order), then `t` has odd order. -/
theorem tame_odd_order {s t : G} (hs : orderOf s ‚âÝ 0) (h : s‚Åª¬π * t * s = t ^ 2) :
    Odd (orderOf t) := by
  set k := orderOf s with hk
  -- Conjugating `t` by `s^k = 1` returns `t`, but the iterate formula says it equals `t^(2^k)`.
  have hconj := conj_pow_iterate h k
  rw [pow_orderOf_eq_one] at hconj
  simp only [inv_one, one_mul, mul_one] at hconj
  -- Hence `t = t^(2^k)`, so `t^(2^k - 1) = 1`.
  have hpos : 1 ‚â§ 2 ^ k := Nat.pos_of_ne_zero (pow_ne_zero _ (by norm_num))
  have hone : t ^ (2 ^ k - 1) = 1 := by
    rw [‚Üê mul_left_inj t, one_mul, ‚Üê pow_succ, Nat.sub_add_cancel hpos, ‚Üê hconj]
  -- So `orderOf t ‚à£ 2^k - 1`.  If `orderOf t` were even, then `2 ‚à£ 2^k` and `2 ‚à£ 2^k - 1`, absurd.
  have hdvd : orderOf t ‚à£ 2 ^ k - 1 := orderOf_dvd_of_pow_eq_one hone
  rcases Nat.even_or_odd (orderOf t) with he | ho
  ¬∑ exfalso
    have hd1 : (2 : ‚Ñï) ‚à£ 2 ^ k - 1 := he.two_dvd.trans hdvd
    have h2p : (2 : ‚Ñï) ‚à£ 2 ^ k := dvd_pow_self 2 hs
    omega
  ¬∑ exact ho

/-- For an element `t` of odd order, `‚ü®t¬≤‚ü© = ‚ü®t‚ü©` (squaring is an automorphism of `‚ü®t‚ü©`). -/
theorem zpowers_sq_eq_of_odd {t : G} (ht : Odd (orderOf t)) :
    Subgroup.zpowers (t ^ 2) = Subgroup.zpowers t := by
  refine le_antisymm (Subgroup.zpowers_le.2 (Subgroup.pow_mem _ (Subgroup.mem_zpowers t) 2))
    (Subgroup.zpowers_le.2 ?_)
  obtain ‚ü®m, hm‚ü© := ht
  rw [Subgroup.mem_zpowers_iff]
  refine ‚ü®(m + 1 : ‚Ñï), ?_‚ü©
  rw [zpow_natCast, ‚Üê pow_mul, show 2 * (m + 1) = orderOf t + 1 by omega, pow_succ,
    pow_orderOf_eq_one, one_mul]

/-- The cyclic subgroup `‚ü®t‚ü©` is normal in `G = ‚ü®s, t‚ü©`.

The proof uses `zpowers_sq_eq_of_odd`: conjugation by `s‚Åª¬π` is the automorphism
`MulAut.conj s‚Åª¬π`,
and `(MulAut.conj s‚Åª¬π) t = s‚Åª¬π t s = t¬≤`, so `(‚ü®t‚ü©).map (conj s‚Åª¬π) = ‚ü®t¬≤‚ü© = ‚ü®t‚ü©` (odd order). Hence
`s` (and trivially `t`) lie in `(‚ü®t‚ü©).normalizer`; since `‚ü®s,t‚ü© = ‚ä§`, the normalizer is `‚ä§`, i.e.
`‚ü®t‚ü©` is normal. -/
theorem zpowers_normal_of_tame {s t : G} [Finite G] (hgen : Subgroup.closure {s, t} = ‚ä§)
    (h : s‚Åª¬π * t * s = t ^ 2) : (Subgroup.zpowers t).Normal := by
  have hodd : Odd (orderOf t) := tame_odd_order (orderOf_pos s).ne' h
  -- Conjugation by `s‚Åª¬π` maps `‚ü®t‚ü©` to `‚ü®s‚Åª¬π t s‚ü© = ‚ü®t¬≤‚ü© = ‚ü®t‚ü©`.
  have hmaps : (Subgroup.zpowers t).map (MulAut.conj s‚Åª¬π).toMonoidHom = Subgroup.zpowers t := by
    have hc : (MulAut.conj s‚Åª¬π).toMonoidHom t = t ^ 2 := by
      show s‚Åª¬π * t * s‚Åª¬π‚Åª¬π = t ^ 2
      rw [inv_inv]; exact h
    rw [MonoidHom.map_zpowers, hc]; exact zpowers_sq_eq_of_odd hodd
  -- Hence `s‚Åª¬π`, and so `s`, and trivially `t`, all normalize `‚ü®t‚ü©`; and `‚ü®s,t‚ü© = ‚ä§`.
  have hs_norm : s ‚àà Subgroup.normalizer (Subgroup.zpowers t) := by
    have hinv := Subgroup.mem_normalizer_iff_map_conj_eq.mpr hmaps
    simpa using Subgroup.inv_mem _ hinv
  have ht_norm : t ‚àà Subgroup.normalizer (Subgroup.zpowers t) :=
    Subgroup.le_normalizer (Subgroup.mem_zpowers t)
  rw [‚Üê Subgroup.normalizer_eq_top_iff, eq_top_iff, ‚Üê hgen, Subgroup.closure_le]
  intro x hx
  simp only [Set.mem_insert_iff, Set.mem_singleton_iff] at hx
  rcases hx with rfl | rfl
  exacts [SetLike.mem_coe.2 hs_norm, SetLike.mem_coe.2 ht_norm]


/-- **Lemma 3.1 (normal 2-subgroups are central).** Every normal 2-subgroup `N` of a finite tame
quotient `‚ü®s,t | s‚Åª¬π t s = t¬≤‚ü©` is central.

Key idea: `N ‚äì ‚ü®t‚ü© = ‚ä•` (coprime orders), so for `n ‚àà N` the commutator `‚ÅÖn,s‚ÅÜ` lies in `N`
(normality) *and* in `‚ü®t‚ü©` (the quotient `G/‚ü®t‚ü©` is cyclic, hence abelian), whence `‚ÅÖn,s‚ÅÜ = 1`;
together with `‚ÅÖn,t‚ÅÜ = 1` this puts `n` in the centralizer of the generators `{s,t}`, i.e. the
centre. -/
theorem tame_normal_two_subgroup_central {s t : G} [Finite G]
    (hgen : Subgroup.closure {s, t} = ‚ä§) (h : s‚Åª¬π * t * s = t ^ 2)
    (N : Subgroup G) [hNnorm : N.Normal] (hN : IsPGroup 2 N) :
    N ‚â§ Subgroup.center G := by
  haveI hCn : (Subgroup.zpowers t).Normal := zpowers_normal_of_tame hgen h
  have hodd : Odd (Nat.card (Subgroup.zpowers t)) := by
    rw [Nat.card_zpowers]; exact tame_odd_order (orderOf_pos s).ne' h
  -- `N ‚äì ‚ü®t‚ü© = ‚ä•` (2-group meets odd cyclic).
  have hinf : N ‚äì Subgroup.zpowers t = ‚ä• := by
    obtain ‚ü®k, hk‚ü© := hN.exists_card_eq
    have hnd : ¬¨ (2 : ‚Ñï) ‚à£ Nat.card (Subgroup.zpowers t) := by
      have := Nat.odd_iff.mp hodd; omega
    have hcop : Nat.Coprime (Nat.card N) (Nat.card (Subgroup.zpowers t)) := by
      rw [hk]; exact ((Nat.prime_two.coprime_iff_not_dvd).mpr hnd).pow_left k
    have hd1 : Nat.card (N ‚äì Subgroup.zpowers t : Subgroup G) ‚à£ Nat.card N :=
      Subgroup.card_dvd_of_le inf_le_left
    have hd2 : Nat.card (N ‚äì Subgroup.zpowers t : Subgroup G) ‚à£ Nat.card (Subgroup.zpowers t) :=
      Subgroup.card_dvd_of_le inf_le_right
    have hcard : Nat.card (N ‚äì Subgroup.zpowers t : Subgroup G) = 1 :=
      Nat.eq_one_of_dvd_coprimes hcop hd1 hd2
    exact Subgroup.eq_bot_of_card_eq _ hcard
  -- `G/‚ü®t‚ü©` is generated by the image of `s` (it is cyclic).
  have hsup : Subgroup.zpowers t ‚äî Subgroup.zpowers s = ‚ä§ := by
    rw [eq_top_iff, ‚Üê hgen, Subgroup.closure_le]
    intro x hx
    simp only [Set.mem_insert_iff, Set.mem_singleton_iff] at hx
    rcases hx with rfl | rfl
    ¬∑ exact SetLike.mem_coe.2 (Subgroup.mem_sup_right (Subgroup.mem_zpowers _))
    ¬∑ exact SetLike.mem_coe.2 (Subgroup.mem_sup_left (Subgroup.mem_zpowers _))
  set œÜ := QuotientGroup.mk' (Subgroup.zpowers t) with hœÜ
  have htmk : œÜ t = 1 := by
    rw [hœÜ, QuotientGroup.mk'_apply, QuotientGroup.eq_one_iff]; exact Subgroup.mem_zpowers t
  have htop : Subgroup.zpowers (œÜ s) = ‚ä§ := by
    have hm := congrArg (Subgroup.map œÜ) hsup
    rwa [Subgroup.map_sup, MonoidHom.map_zpowers, MonoidHom.map_zpowers, htmk,
      Subgroup.zpowers_one_eq_bot, bot_sup_eq,
      Subgroup.map_top_of_surjective _ (QuotientGroup.mk'_surjective _)] at hm
  -- Membership in the centre: reduce to commuting with the generators `s, t`.
  intro n hn
  have hct : Commute n t := by
    have hcN : n * t * n‚Åª¬π * t‚Åª¬π ‚àà N := by
      have h1 : n * (t * n‚Åª¬π * t‚Åª¬π) ‚àà N := N.mul_mem hn (hNnorm.conj_mem _ (N.inv_mem hn) t)
      rwa [‚Üê mul_assoc, ‚Üê mul_assoc] at h1
    have hcT : n * t * n‚Åª¬π * t‚Åª¬π ‚àà Subgroup.zpowers t :=
      Subgroup.mul_mem _ (hCn.conj_mem t (Subgroup.mem_zpowers t) n)
        (Subgroup.inv_mem _ (Subgroup.mem_zpowers t))
    exact commutatorElement_eq_one_iff_commute.mp
      (Subgroup.mem_bot.mp (hinf ‚ñ∏ Subgroup.mem_inf.mpr ‚ü®hcN, hcT‚ü©))
  have hcs : Commute n s := by
    have hcN : n * s * n‚Åª¬π * s‚Åª¬π ‚àà N := by
      have h1 : n * (s * n‚Åª¬π * s‚Åª¬π) ‚àà N := N.mul_mem hn (hNnorm.conj_mem _ (N.inv_mem hn) s)
      rwa [‚Üê mul_assoc, ‚Üê mul_assoc] at h1
    -- `n*s*n‚Åª¬π*s‚Åª¬π ‚àà ‚ü®t‚ü©` since `G/‚ü®t‚ü©` is abelian (cyclic, generated by the image of `s`).
    have hcomm_q : Commute (œÜ n) (œÜ s) := by
      have hmemq : œÜ n ‚àà Subgroup.zpowers (œÜ s) := by rw [htop]; exact Subgroup.mem_top _
      obtain ‚ü®k, hk‚ü© := hmemq
      rw [‚Üê hk]; exact (Commute.refl (œÜ s)).zpow_left k
    have hcT : n * s * n‚Åª¬π * s‚Åª¬π ‚àà Subgroup.zpowers t := by
      rw [‚Üê QuotientGroup.eq_one_iff, ‚Üê QuotientGroup.mk'_apply, ‚Üê hœÜ,
        map_mul, map_mul, map_mul, map_inv, map_inv, hcomm_q.eq]
      group
    exact commutatorElement_eq_one_iff_commute.mp
      (Subgroup.mem_bot.mp (hinf ‚ñ∏ Subgroup.mem_inf.mpr ‚ü®hcN, hcT‚ü©))
  -- Commuting with `s` and `t` ‚üπ commuting with all of `‚ü®s,t‚ü© = ‚ä§`.
  rw [Subgroup.mem_center_iff]
  intro g
  have hg : g ‚àà Subgroup.centralizer {n} := by
    have hle : Subgroup.closure ({s, t} : Set G) ‚â§ Subgroup.centralizer {n} := by
      rw [Subgroup.closure_le]
      intro x hx
      simp only [Set.mem_insert_iff, Set.mem_singleton_iff] at hx
      refine Subgroup.mem_centralizer_iff.mpr ?_
      rintro m hm
      rw [Set.mem_singleton_iff] at hm; subst hm
      rcases hx with rfl | rfl
      ¬∑ exact hcs
      ¬∑ exact hct
    exact (hgen ‚ñ∏ hle) (Subgroup.mem_top g)
  exact ((Subgroup.mem_centralizer_iff.mp hg) n (Set.mem_singleton n)).symm

end GQ2.Tame

