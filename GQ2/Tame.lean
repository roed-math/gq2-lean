import Mathlib

/-!
# Lemma 3.1 — structure of finite tame quotients

Paper Lemma 3.1: *In every finite quotient generated by `s, t` with `t^s = t^2`, the element
`t` has odd order, and the quotient has the form `C_e ⋊ C_n` (`e` odd) with `s⁻¹ t s = t^2`.
Every normal 2-subgroup of such a quotient is central and lies in the unramified cyclic
direction.*

Here the paper's `t^s = t^2` means `s⁻¹ * t * s = t^2` (right-conjugation convention).

The first assertion — `t` has odd order — is elementary and is **proved in full** below.
The remaining structural claims (`C_e ⋊ C_n` shape, centrality of normal 2-subgroups) are
stated with `sorry`; they need semidirect-product recognition that is more involved.
-/

namespace GQ2.Tame

open scoped Classical

variable {G : Type*} [Group G]

/-- Iterated conjugation: `(sⁿ)⁻¹ t sⁿ = t^(2ⁿ)`, from the tame relation `s⁻¹ t s = t²`. -/
theorem conj_pow_iterate {s t : G} (h : s⁻¹ * t * s = t ^ 2) :
    ∀ n : ℕ, (s ^ n)⁻¹ * t * s ^ n = t ^ (2 ^ n) := by
  intro n
  induction n with
  | zero => simp
  | succ k ih =>
    have step : (s ^ (k + 1))⁻¹ * t * s ^ (k + 1)
        = (s ^ k)⁻¹ * (s⁻¹ * t * s) * s ^ k := by
      rw [pow_succ]
      group
    rw [step, h]
    have conj_sq : (s ^ k)⁻¹ * t ^ 2 * s ^ k = ((s ^ k)⁻¹ * t * s ^ k) ^ 2 := by
      rw [pow_two, pow_two]; group
    rw [conj_sq, ih, ← pow_mul, ← pow_succ]

/-- **Lemma 3.1 (first assertion).** If a finite group is generated by `s, t` with the tame
relation `s⁻¹ t s = t²` (so in particular `s` has finite order), then `t` has odd order. -/
theorem tame_odd_order {s t : G} (hs : orderOf s ≠ 0) (h : s⁻¹ * t * s = t ^ 2) :
    Odd (orderOf t) := by
  set k := orderOf s with hk
  -- Conjugating `t` by `s^k = 1` returns `t`, but the iterate formula says it equals `t^(2^k)`.
  have hconj := conj_pow_iterate h k
  rw [pow_orderOf_eq_one] at hconj
  simp only [inv_one, one_mul, mul_one] at hconj
  -- Hence `t = t^(2^k)`, so `t^(2^k - 1) = 1`.
  have hpos : 1 ≤ 2 ^ k := Nat.pos_of_ne_zero (pow_ne_zero _ (by norm_num))
  have hone : t ^ (2 ^ k - 1) = 1 := by
    have heq : t ^ (2 ^ k - 1) * t = t := by
      rw [← pow_succ, Nat.sub_add_cancel hpos, ← hconj]
    have heq' : t ^ (2 ^ k - 1) * t = 1 * t := by rw [one_mul]; exact heq
    exact mul_right_cancel heq'
  -- So `orderOf t ∣ 2^k - 1`.  If `orderOf t` were even, then `2 ∣ 2^k` and `2 ∣ 2^k - 1`, absurd.
  have hdvd : orderOf t ∣ 2 ^ k - 1 := orderOf_dvd_of_pow_eq_one hone
  rcases Nat.even_or_odd (orderOf t) with he | ho
  · exfalso
    obtain ⟨r, hr⟩ := he
    have h2ot : (2 : ℕ) ∣ orderOf t := ⟨r, by omega⟩
    have hd1 : (2 : ℕ) ∣ 2 ^ k - 1 := dvd_trans h2ot hdvd
    have h2p : (2 : ℕ) ∣ 2 ^ k := dvd_pow_self 2 hs
    omega
  · exact ho

/-- For an element `t` of odd order, `⟨t²⟩ = ⟨t⟩` (squaring is an automorphism of `⟨t⟩`). -/
theorem zpowers_sq_eq_of_odd {t : G} (ht : Odd (orderOf t)) :
    Subgroup.zpowers (t ^ 2) = Subgroup.zpowers t := by
  refine le_antisymm (Subgroup.zpowers_le.2 (Subgroup.pow_mem _ (Subgroup.mem_zpowers t) 2))
    (Subgroup.zpowers_le.2 ?_)
  obtain ⟨m, hm⟩ := ht
  rw [Subgroup.mem_zpowers_iff]
  refine ⟨(m + 1 : ℕ), ?_⟩
  rw [zpow_natCast, ← pow_mul, show 2 * (m + 1) = orderOf t + 1 by omega, pow_succ,
    pow_orderOf_eq_one, one_mul]

/-- The cyclic subgroup `⟨t⟩` is normal in `G = ⟨s, t⟩`.  *(Target; proof deferred.)*

Proof plan (uses `zpowers_sq_eq_of_odd`): conjugation by `s⁻¹` is the automorphism `MulAut.conj s⁻¹`,
and `(MulAut.conj s⁻¹) t = s⁻¹ t s = t²`, so `(⟨t⟩).map (conj s⁻¹) = ⟨t²⟩ = ⟨t⟩` (odd order). Hence
`s` (and trivially `t`) lie in `(⟨t⟩).normalizer`; since `⟨s,t⟩ = ⊤`, the normalizer is `⊤`, i.e.
`⟨t⟩` is normal. The remaining Lean work is `MulAut.conj`/`Subgroup.map`/`normalizer` API plumbing. -/
theorem zpowers_normal_of_tame {s t : G} [Finite G] (hgen : Subgroup.closure {s, t} = ⊤)
    (h : s⁻¹ * t * s = t ^ 2) : (Subgroup.zpowers t).Normal := by
  have hodd : Odd (orderOf t) := tame_odd_order (orderOf_pos s).ne' h
  -- Conjugation by `s⁻¹` maps `⟨t⟩` to `⟨s⁻¹ t s⟩ = ⟨t²⟩ = ⟨t⟩`.
  have hmaps : (Subgroup.zpowers t).map (MulAut.conj s⁻¹).toMonoidHom = Subgroup.zpowers t := by
    have hc : (MulAut.conj s⁻¹).toMonoidHom t = t ^ 2 := by
      show s⁻¹ * t * s⁻¹⁻¹ = t ^ 2
      rw [inv_inv]; exact h
    rw [MonoidHom.map_zpowers, hc]; exact zpowers_sq_eq_of_odd hodd
  -- Hence `s⁻¹`, and so `s`, and trivially `t`, all normalize `⟨t⟩`; and `⟨s,t⟩ = ⊤`.
  have hs_norm : s ∈ Subgroup.normalizer (Subgroup.zpowers t) := by
    have hinv := Subgroup.mem_normalizer_iff_map_conj_eq.mpr hmaps
    simpa using Subgroup.inv_mem _ hinv
  have ht_norm : t ∈ Subgroup.normalizer (Subgroup.zpowers t) :=
    Subgroup.le_normalizer (Subgroup.mem_zpowers t)
  rw [← Subgroup.normalizer_eq_top_iff, eq_top_iff, ← hgen, Subgroup.closure_le]
  intro x hx
  simp only [Set.mem_insert_iff, Set.mem_singleton_iff] at hx
  rcases hx with rfl | rfl
  · exact SetLike.mem_coe.2 hs_norm
  · exact SetLike.mem_coe.2 ht_norm


/-- **Lemma 3.1 (normal 2-subgroups are central).** Every normal 2-subgroup `N` of a finite tame
quotient `⟨s,t | s⁻¹ t s = t²⟩` is central.

Key idea: `N ⊓ ⟨t⟩ = ⊥` (coprime orders), so for `n ∈ N` the commutator `⁅n,s⁆` lies in `N`
(normality) *and* in `⟨t⟩` (the quotient `G/⟨t⟩` is cyclic, hence abelian), whence `⁅n,s⁆ = 1`;
together with `⁅n,t⁆ = 1` this puts `n` in the centralizer of the generators `{s,t}`, i.e. the
centre. -/
theorem tame_normal_two_subgroup_central {s t : G} [Finite G]
    (hgen : Subgroup.closure {s, t} = ⊤) (h : s⁻¹ * t * s = t ^ 2)
    (N : Subgroup G) [hNnorm : N.Normal] (hN : IsPGroup 2 N) :
    N ≤ Subgroup.center G := by
  haveI hCn : (Subgroup.zpowers t).Normal := zpowers_normal_of_tame hgen h
  have hodd : Odd (Nat.card (Subgroup.zpowers t)) := by
    rw [Nat.card_zpowers]; exact tame_odd_order (orderOf_pos s).ne' h
  -- `N ⊓ ⟨t⟩ = ⊥` (2-group meets odd cyclic).
  have hinf : N ⊓ Subgroup.zpowers t = ⊥ := by
    obtain ⟨k, hk⟩ := hN.exists_card_eq
    have hnd : ¬ (2 : ℕ) ∣ Nat.card (Subgroup.zpowers t) := by
      have := Nat.odd_iff.mp hodd; omega
    have hcop : Nat.Coprime (Nat.card N) (Nat.card (Subgroup.zpowers t)) := by
      rw [hk]; exact ((Nat.prime_two.coprime_iff_not_dvd).mpr hnd).pow_left k
    have hd1 : Nat.card (N ⊓ Subgroup.zpowers t : Subgroup G) ∣ Nat.card N :=
      Subgroup.card_dvd_of_le inf_le_left
    have hd2 : Nat.card (N ⊓ Subgroup.zpowers t : Subgroup G) ∣ Nat.card (Subgroup.zpowers t) :=
      Subgroup.card_dvd_of_le inf_le_right
    have hcard : Nat.card (N ⊓ Subgroup.zpowers t : Subgroup G) = 1 :=
      Nat.eq_one_of_dvd_coprimes hcop hd1 hd2
    exact Subgroup.eq_bot_of_card_eq _ hcard
  -- `G/⟨t⟩` is generated by the image of `s` (it is cyclic).
  have hsup : Subgroup.zpowers t ⊔ Subgroup.zpowers s = ⊤ := by
    rw [eq_top_iff, ← hgen, Subgroup.closure_le]
    intro x hx
    simp only [Set.mem_insert_iff, Set.mem_singleton_iff] at hx
    rcases hx with rfl | rfl
    · exact SetLike.mem_coe.2 (Subgroup.mem_sup_right (Subgroup.mem_zpowers _))
    · exact SetLike.mem_coe.2 (Subgroup.mem_sup_left (Subgroup.mem_zpowers _))
  set φ := QuotientGroup.mk' (Subgroup.zpowers t) with hφ
  have htmk : φ t = 1 := by rw [hφ, QuotientGroup.mk'_apply, QuotientGroup.eq_one_iff]; exact Subgroup.mem_zpowers t
  have htop : Subgroup.zpowers (φ s) = ⊤ := by
    have hm := congrArg (Subgroup.map φ) hsup
    rwa [Subgroup.map_sup, MonoidHom.map_zpowers, MonoidHom.map_zpowers, htmk,
      Subgroup.zpowers_one_eq_bot, bot_sup_eq,
      Subgroup.map_top_of_surjective _ (QuotientGroup.mk'_surjective _)] at hm
  -- Membership in the centre: reduce to commuting with the generators `s, t`.
  intro n hn
  have hct : Commute n t := by
    have hcN : n * t * n⁻¹ * t⁻¹ ∈ N := by
      have h1 : n * (t * n⁻¹ * t⁻¹) ∈ N := N.mul_mem hn (hNnorm.conj_mem _ (N.inv_mem hn) t)
      rwa [← mul_assoc, ← mul_assoc] at h1
    have hcT : n * t * n⁻¹ * t⁻¹ ∈ Subgroup.zpowers t :=
      Subgroup.mul_mem _ (hCn.conj_mem t (Subgroup.mem_zpowers t) n)
        (Subgroup.inv_mem _ (Subgroup.mem_zpowers t))
    have hz : n * t * n⁻¹ * t⁻¹ = 1 :=
      Subgroup.mem_bot.mp (hinf ▸ Subgroup.mem_inf.mpr ⟨hcN, hcT⟩)
    exact commutatorElement_eq_one_iff_commute.mp hz
  have hcs : Commute n s := by
    have hcN : n * s * n⁻¹ * s⁻¹ ∈ N := by
      have h1 : n * (s * n⁻¹ * s⁻¹) ∈ N := N.mul_mem hn (hNnorm.conj_mem _ (N.inv_mem hn) s)
      rwa [← mul_assoc, ← mul_assoc] at h1
    -- `n*s*n⁻¹*s⁻¹ ∈ ⟨t⟩` since `G/⟨t⟩` is abelian (cyclic, generated by the image of `s`).
    have hcomm_q : Commute (φ n) (φ s) := by
      have hmemq : φ n ∈ Subgroup.zpowers (φ s) := by rw [htop]; exact Subgroup.mem_top _
      obtain ⟨k, hk⟩ := hmemq
      rw [← hk]; exact (Commute.refl (φ s)).zpow_left k
    have hcT : n * s * n⁻¹ * s⁻¹ ∈ Subgroup.zpowers t := by
      rw [← QuotientGroup.eq_one_iff, ← QuotientGroup.mk'_apply, ← hφ,
        map_mul, map_mul, map_mul, map_inv, map_inv, hcomm_q.eq]
      group
    have hz : n * s * n⁻¹ * s⁻¹ = 1 :=
      Subgroup.mem_bot.mp (hinf ▸ Subgroup.mem_inf.mpr ⟨hcN, hcT⟩)
    exact commutatorElement_eq_one_iff_commute.mp hz
  -- Commuting with `s` and `t` ⟹ commuting with all of `⟨s,t⟩ = ⊤`.
  rw [Subgroup.mem_center_iff]
  intro g
  have hg : g ∈ Subgroup.centralizer {n} := by
    have hle : Subgroup.closure ({s, t} : Set G) ≤ Subgroup.centralizer {n} := by
      rw [Subgroup.closure_le]
      intro x hx
      simp only [Set.mem_insert_iff, Set.mem_singleton_iff] at hx
      refine Subgroup.mem_centralizer_iff.mpr ?_
      rintro m hm
      rw [Set.mem_singleton_iff] at hm; subst hm
      rcases hx with rfl | rfl
      · exact hcs
      · exact hct
    exact (hgen ▸ hle) (Subgroup.mem_top g)
  exact ((Subgroup.mem_centralizer_iff.mp hg) n (Set.mem_singleton n)).symm

end GQ2.Tame

