import Mathlib

/-!
# Lemma 3.1 — structure of finite tame quotients

Paper Lemma 3.1: *In every finite quotient generated by `s, t` with `t^s = t^2`, the element
`t` has odd order, and the quotient has the form `C_e ⋊ C_n` (`e` odd) with `s⁻¹ t s = t^2`.
Every normal 2-subgroup of such a quotient is central and lies in the unramified cyclic
direction.*

Here the paper's `t^s = t^2` means `s⁻¹ * t * s = t^2` (right-conjugation convention).

The first assertion — `t` has odd order — is elementary and is **proved in full** below.
The remaining structural claims (`C_e ⋊ C_n` shape, centrality of normal 2-subgroups) are
stated with `sorry`; they need semidirect-product recognition that is more involved.
-/

namespace GQ2.Tame

open scoped Classical

variable {G : Type*} [Group G]

/-- Iterated conjugation: `(sⁿ)⁻¹ t sⁿ = t^(2ⁿ)`, from the tame relation `s⁻¹ t s = t²`. -/
theorem conj_pow_iterate {s t : G} (h : s⁻¹ * t * s = t ^ 2) :
    ∀ n : ℕ, (s ^ n)⁻¹ * t * s ^ n = t ^ (2 ^ n) := by
  intro n
  induction n with
  | zero => simp
  | succ k ih =>
    have step : (s ^ (k + 1))⁻¹ * t * s ^ (k + 1)
        = (s ^ k)⁻¹ * (s⁻¹ * t * s) * s ^ k := by
      rw [pow_succ]
      group
    rw [step, h]
    have conj_sq : (s ^ k)⁻¹ * t ^ 2 * s ^ k = ((s ^ k)⁻¹ * t * s ^ k) ^ 2 := by
      rw [pow_two, pow_two]; group
    rw [conj_sq, ih, ← pow_mul, ← pow_succ]

/-- **Lemma 3.1 (first assertion).** If a finite group is generated by `s, t` with the tame
relation `s⁻¹ t s = t²` (so in particular `s` has finite order), then `t` has odd order. -/
theorem tame_odd_order {s t : G} (hs : orderOf s ≠ 0) (h : s⁻¹ * t * s = t ^ 2) :
    Odd (orderOf t) := by
  set k := orderOf s with hk
  -- Conjugating `t` by `s^k = 1` returns `t`, but the iterate formula says it equals `t^(2^k)`.
  have hconj := conj_pow_iterate h k
  rw [pow_orderOf_eq_one] at hconj
  simp only [inv_one, one_mul, mul_one] at hconj
  -- Hence `t = t^(2^k)`, so `t^(2^k - 1) = 1`.
  have hpos : 1 ≤ 2 ^ k := Nat.pos_of_ne_zero (pow_ne_zero _ (by norm_num))
  have hone : t ^ (2 ^ k - 1) = 1 := by
    have heq : t ^ (2 ^ k - 1) * t = t := by
      rw [← pow_succ, Nat.sub_add_cancel hpos, ← hconj]
    have heq' : t ^ (2 ^ k - 1) * t = 1 * t := by rw [one_mul]; exact heq
    exact mul_right_cancel heq'
  -- So `orderOf t ∣ 2^k - 1`.  If `orderOf t` were even, then `2 ∣ 2^k` and `2 ∣ 2^k - 1`, absurd.
  have hdvd : orderOf t ∣ 2 ^ k - 1 := orderOf_dvd_of_pow_eq_one hone
  rcases Nat.even_or_odd (orderOf t) with he | ho
  · exfalso
    obtain ⟨r, hr⟩ := he
    have h2ot : (2 : ℕ) ∣ orderOf t := ⟨r, by omega⟩
    have hd1 : (2 : ℕ) ∣ 2 ^ k - 1 := dvd_trans h2ot hdvd
    have h2p : (2 : ℕ) ∣ 2 ^ k := dvd_pow_self 2 hs
    omega
  · exact ho

/-- **Lemma 3.1 (structure).** A finite group generated by `s, t` with `s⁻¹ t s = t²` has a
normal cyclic subgroup of odd order (the image of `⟨t⟩`) with cyclic quotient — i.e. the
`C_e ⋊ C_n` shape with `e` odd. *(Statement scaffold; proof deferred.)* -/
theorem tame_semidirect {s t : G} [Finite G] (hgen : Subgroup.closure {s, t} = ⊤)
    (h : s⁻¹ * t * s = t ^ 2) :
    ∃ C K : Subgroup G, C.Normal ∧ Odd (Nat.card C) ∧ IsCyclic C ∧ IsCyclic K ∧
      C.IsComplement' K := by
  sorry

/-- **Lemma 3.1 (normal 2-subgroups are central & unramified).** *(Statement scaffold.)* -/
theorem tame_normal_two_subgroup_central {s t : G} [Finite G]
    (hgen : Subgroup.closure {s, t} = ⊤) (h : s⁻¹ * t * s = t ^ 2)
    (N : Subgroup G) [N.Normal] (hN : IsPGroup 2 N) :
    N ≤ Subgroup.center G := by
  sorry

end GQ2.Tame
