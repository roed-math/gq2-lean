/-! ## Terminal-case group-theory foundation

The coprime-centralization mechanism behind Lemma 9.2's odd normal lift `Г‘ в—Ғ Y`: an
odd-order subgroup acting on the scalar stack `L_Y` (a `Y`-central 2-group) centralizes it.
This is `GQ2.comm_bot_of_scalarChain` (the Lemma 7.2 proof) unpacked at the `IsScalarStack` datum. -/


/-- **Coprime centralization** (Lemma 9.2 mechanism, В§9.1): an odd-order subgroup `N` acting
on a scalar stack `L` (a `Y`-central 2-group, `SectionSeven.IsScalarStack`) centralizes it вҖ”
`вҒ…N, LвҒҶ = вҠҘ`.  This is how the odd normal lift `Г‘` of Lemma 9.2 centralizes `L_Y` (its
uniqueness/normality then follow).  Proved from `comm_bot_of_scalarChain`; reusable by the
Lemma 9.2 structural subproof the В§9 induction. -/
theorem scalarStack_centralized_of_coprime {Y : Type} [Group Y] [Finite Y]
    {L : Subgroup Y} (hstack : SectionSeven.IsScalarStack L) {N : Subgroup Y}
    (hcop : Nat.Coprime (Nat.card N) (Nat.card L)) : вҒ…N, LвҒҶ = вҠҘ := by
  obtain вҹЁn, c, hc0, hcn, hmono, _, hcommвҹ© := hstack
  have h := comm_bot_of_scalarChain n N c hc0 hmono hcomm (by rw [hcn]; exact hcop)
  rwa [hcn] at h

/-! ## Tame 2-nilpotency

The gating foundation for Lemma 9.2: a finite quotient `H` of the tame group `Ttame`
(generated by `s, t` with `sвҒ»В№ t s = tВІ`) is 2-nilpotent вҖ” `OВІ(H)` has odd order.  `вҹЁtвҹ©` is
odd (`Tame.tame_odd_order`) and normal (`Tame.zpowers_normal_of_tame`), the quotient `H в§ё вҹЁtвҹ©`
is cyclic, and a finite group with an odd normal subgroup and cyclic quotient is 2-nilpotent
(the odd complement is the preimage of the odd part of the cyclic quotient).  This lets the В§9 induction
build the odd normal lift `Г‘ в—Ғ Y` via SchurвҖ“Zassenhaus (`oddOrder_twoQuotient_split`). -/

/-- A finite **cyclic** group `Q` has a normal subgroup `QвӮҖ` of odd order (`= вҹЁg^{2бөғ}вҹ©`, the odd
part) such that the `2бөғ`-power of every element lands in `QвӮҖ` (i.e. `Q в§ё QвӮҖ` is a 2-group,
expressed membership-wise to avoid forming the quotient here). -/
theorem exists_normal_odd_pow_mem_of_cyclic {Q : Type*} [Group Q] [Finite Q]
    (hcyc : IsCyclic Q) :
    вҲғ Q0 : Subgroup Q, Q0.Normal вҲ§ Odd (Nat.card Q0) вҲ§ вҲҖ x : Q, вҲғ k : в„•, x ^ 2 ^ k вҲҲ Q0 := by
  obtain вҹЁg, hgвҹ© := hcyc.exists_generator
  have hcomm : вҲҖ x y : Q, x * y = y * x := by
    intro x y
    obtain вҹЁi, rflвҹ© := Subgroup.mem_zpowers_iff.mp (hg x)
    obtain вҹЁj, rflвҹ© := Subgroup.mem_zpowers_iff.mp (hg y)
    exact (Commute.zpow_zpow (Commute.refl g) i j).eq
  have hgtop : Subgroup.zpowers g = вҠӨ := by rw [eq_top_iff]; intro x _; exact hg x
  set n := Nat.card Q with hn
  have hnpos : 0 < n := Nat.card_pos
  have hord : orderOf g = n := by
    rw [вҶҗ Nat.card_zpowers g, hgtop]; exact Nat.card_congr (Subgroup.topEquiv.toEquiv)
  set P2 := 2 ^ (n.factorization 2) with hP2
  have hP2pos : 0 < P2 := pow_pos (by norm_num) _
  have hsplit : P2 * (n / P2) = n := Nat.ordProj_mul_ordCompl_eq_self n 2
  have hdvd : P2 вҲЈ n := вҹЁn / P2, hsplit.symmвҹ©
  have hbodd : В¬ 2 вҲЈ (n / P2) := Nat.not_dvd_ordCompl Nat.prime_two hnpos.ne'
  refine вҹЁSubgroup.zpowers (g ^ P2), ?_, ?_, ?_вҹ©
  В· refine вҹЁfun w hw q => ?_вҹ©
    have hqw : q * w * qвҒ»В№ = w := by rw [hcomm q w]; group
    rw [hqw]; exact hw
  В· rw [Nat.card_zpowers, orderOf_pow' g hP2pos.ne', hord, Nat.gcd_comm, Nat.gcd_eq_left hdvd]
    exact Nat.odd_iff.mpr (Nat.two_dvd_ne_zero.mp hbodd)
  В· intro x
    refine вҹЁn.factorization 2, ?_вҹ©
    obtain вҹЁi, rflвҹ© := Subgroup.mem_zpowers_iff.mp (hg x)
    refine Subgroup.mem_zpowers_iff.mpr вҹЁi, ?_вҹ©
    rw [вҶҗ hP2, вҶҗ zpow_natCast (g ^ i) P2, вҶҗ zpow_natCast g P2, вҶҗ zpow_mul, вҶҗ zpow_mul, mul_comm]

/-- **2-nilpotency from a cyclic quotient.** A finite group `H` with a normal subgroup `C` of
odd order and *cyclic* quotient `H в§ё C` has a normal subgroup `N` of odd order with 2-group
quotient (necessarily `N = OВІ(H)`): the preimage of the odd part of the cyclic `H в§ё C`. -/
theorem exists_normal_odd_twoQuotient_of_cyclic_quotient {H : Type*} [Group H] [Finite H]
    (C : Subgroup H) [C.Normal] (hC : Odd (Nat.card C)) (hcyc : IsCyclic (H в§ё C)) :
    вҲғ N : Subgroup H, вҲғ _ : N.Normal, Odd (Nat.card N) вҲ§ IsPGroup 2 (H в§ё N) := by
  obtain вҹЁQ0, hQ0norm, hQ0odd, hQ0powвҹ© := exists_normal_odd_pow_mem_of_cyclic hcyc
  set f : H вҶ’* H в§ё C := QuotientGroup.mk' C with hf
  have hfsurj : Function.Surjective f := QuotientGroup.mk'_surjective C
  refine вҹЁQ0.comap f, hQ0norm.comap f, ?_, ?_вҹ©
  В· -- `Nat.card (comap f Q0) = card C * card Q0`, both odd, via index bookkeeping.
    have hidx : (Q0.comap f).index = Q0.index := Subgroup.index_comap_of_surjective Q0 hfsurj
    have hcardC : Nat.card C * C.index = Nat.card H := Subgroup.card_mul_index C
    have hCQ : C.index = Nat.card (H в§ё C) := rfl
    have hcardN : Nat.card (Q0.comap f) * (Q0.comap f).index = Nat.card H :=
      Subgroup.card_mul_index _
    have hcardQ0 : Nat.card Q0 * Q0.index = Nat.card (H в§ё C) := Subgroup.card_mul_index Q0
    have hNidx_pos : 0 < (Q0.comap f).index := Nat.pos_of_ne_zero Subgroup.index_ne_zero_of_finite
    have key : Nat.card (Q0.comap f) = Nat.card C * Nat.card Q0 := by
      apply Nat.eq_of_mul_eq_mul_right hNidx_pos
      rw [hcardN, hidx, mul_assoc, hcardQ0, вҶҗ hCQ, hcardC]
    rw [key]; exact hC.mul hQ0odd
  В· -- `H в§ё N` is a 2-group: every element's `2бөҸ`-power lifts into `Q0`.
    intro x
    obtain вҹЁy, rflвҹ© := QuotientGroup.mk'_surjective (Q0.comap f) x
    obtain вҹЁk, hkвҹ© := hQ0pow (f y)
    refine вҹЁk, ?_вҹ©
    rw [вҶҗ map_pow, QuotientGroup.mk'_apply, QuotientGroup.eq_one_iff, Subgroup.mem_comap, map_pow]
    exact hk

/-- **Tame 2-nilpotency (Lemma 3.1 structural content).** A finite group generated by `s, t`
with the tame relation `sвҒ»В№ t s = tВІ` is 2-nilpotent: it has a normal subgroup `N` of odd order
with 2-group quotient (`N = OВІ(H)`).  `C = вҹЁtвҹ©` is odd (`Tame.tame_odd_order`) and normal
(`Tame.zpowers_normal_of_tame`), and `H в§ё C` is cyclic (generated by the image of `s`, since
`t вҶҰ 1`); apply `exists_normal_odd_twoQuotient_of_cyclic_quotient`.  This is the foundation
Lemma 9.2 rests on вҖ” the odd normal lift `Г‘` of the В§9 induction lives over `OВІ(H)`. -/
theorem tame_two_nilpotent {H : Type*} [Group H] [Finite H] {s t : H}
    (hgen : Subgroup.closure {s, t} = вҠӨ) (h : sвҒ»В№ * t * s = t ^ 2) :
    вҲғ N : Subgroup H, вҲғ _ : N.Normal, Odd (Nat.card N) вҲ§ IsPGroup 2 (H в§ё N) := by
  haveI hCnorm : (Subgroup.zpowers t).Normal := GQ2.Tame.zpowers_normal_of_tame hgen h
  have hCodd : Odd (Nat.card (Subgroup.zpowers t)) := by
    rw [Nat.card_zpowers]; exact GQ2.Tame.tame_odd_order (orderOf_pos s).ne' h
  have hcyc : IsCyclic (H в§ё Subgroup.zpowers t) := by
    set ПҶ := QuotientGroup.mk' (Subgroup.zpowers t) with hПҶ
    have hsup : Subgroup.zpowers t вҠ” Subgroup.zpowers s = вҠӨ := by
      rw [eq_top_iff, вҶҗ hgen, Subgroup.closure_le]
      intro x hx
      simp only [Set.mem_insert_iff, Set.mem_singleton_iff] at hx
      rcases hx with rfl | rfl
      В· exact SetLike.mem_coe.2 (Subgroup.mem_sup_right (Subgroup.mem_zpowers _))
      В· exact SetLike.mem_coe.2 (Subgroup.mem_sup_left (Subgroup.mem_zpowers _))
    have htmk : ПҶ t = 1 := by
      rw [hПҶ, QuotientGroup.mk'_apply, QuotientGroup.eq_one_iff]; exact Subgroup.mem_zpowers t
    have htop : Subgroup.zpowers (ПҶ s) = вҠӨ := by
      have hm := congrArg (Subgroup.map ПҶ) hsup
      rwa [Subgroup.map_sup, MonoidHom.map_zpowers, MonoidHom.map_zpowers, htmk,
        Subgroup.zpowers_one_eq_bot, bot_sup_eq,
        Subgroup.map_top_of_surjective _ (QuotientGroup.mk'_surjective _)] at hm
    exact вҹЁвҹЁПҶ s, fun x => htop.ge (Subgroup.mem_top x)вҹ©вҹ©
  exact exists_normal_odd_twoQuotient_of_cyclic_quotient (Subgroup.zpowers t) hCodd hcyc

/-! ## Lemma 9.2 вҖ” the odd normal complement `Г‘ в—Ғ Y`

For a terminal target `1 вҶ’ L_Y вҶ’ Y вҶ’ H вҶ’ 1` (`L_Y` a scalar-stack 2-group, `H` tame hence
2-nilpotent by `tame_two_nilpotent`), SchurвҖ“Zassenhaus inside `P = ПҖ_YвҒ»В№(OВІH)` produces an odd
complement `Г‘` to `L_Y`, which the scalar-stack centralization
(`scalarStack_centralized_of_coprime`)
forces to be *normal in `Y`* (`Г‘` = the odd-order elements of `P`).  The output bundle вҖ” `Г‘ в—Ғ Y`
odd, `Y/Г‘` a 2-group, `Г‘ вҲ© L_Y = вҠҘ`, `ПҖ_Y(Г‘) = OВІH`, `Г‘В·L_Y = ПҖ_YвҒ»В№(OВІH)` вҖ” is exactly the data
the В§9 induction feeds to `coprime_fiber_product` (Lemma 9.1) for `Y вү… H Г—_{HвӮӮ} (Y/Г‘)`. -/

/-- Odd divides odd. -/
private theorem odd_of_dvd {a b : в„•} (hab : a вҲЈ b) (hb : Odd b) : Odd a := by
  rcases hab with вҹЁc, rflвҹ©; rw [Nat.odd_mul] at hb; exact hb.1

/-- SchurвҖ“Zassenhaus: the odd complement `Г‘` to `L` inside `P = ПҖвҒ»В№(M)`, where `L = ker ПҖ` is a
2-group and `M в—Ғ H` is odd. -/
theorem sz_odd_complement {H Y : Type} [Group H] [Group Y] [Finite Y]
    (piY : Y вҶ’* H) (hpi : Function.Surjective piY)
    (L : Subgroup Y) (hkerL : piY.ker = L)
    (M : Subgroup H) [M.Normal]
    (hMcop : Nat.Coprime (Nat.card L) (Nat.card M)) :
    вҲғ Ntil : Subgroup Y, Ntil вүӨ M.comap piY вҲ§ Ntil вҠ“ L = вҠҘ вҲ§ Ntil вҠ” L = M.comap piY вҲ§
      Nat.card Ntil = Nat.card M := by
  haveI : Finite H := Finite.of_surjective piY hpi
  haveI hLn : L.Normal := hkerL в–ё piY.normal_ker
  set P := M.comap piY with hPdef
  have hLP : L вүӨ P := by
    intro x hx
    rw [hPdef, Subgroup.mem_comap, вҶҗ hkerL, MonoidHom.mem_ker] at *
    rw [hx]; exact M.one_mem
  -- card P = card L * card M
  have hLindex : L.index = Nat.card H := by
    rw [Subgroup.index_eq_card, вҶҗ hkerL]
    exact Nat.card_congr (QuotientGroup.quotientKerEquivOfSurjective piY hpi).toEquiv
  have hPindex : P.index = M.index := Subgroup.index_comap_of_surjective M hpi
  have hcardY_L : Nat.card L * Nat.card H = Nat.card Y := by
    rw [вҶҗ hLindex]; exact Subgroup.card_mul_index L
  have hcardH_M : Nat.card M * M.index = Nat.card H := Subgroup.card_mul_index M
  have hcardP : Nat.card P * M.index = Nat.card Y := by
    rw [вҶҗ hPindex]; exact Subgroup.card_mul_index P
  have hMindex_pos : 0 < M.index := Nat.pos_of_ne_zero Subgroup.index_ne_zero_of_finite
  have hcardP_eq : Nat.card P = Nat.card L * Nat.card M := by
    apply Nat.eq_of_mul_eq_mul_right hMindex_pos
    rw [hcardP, mul_assoc, hcardH_M, hcardY_L]
  -- Work inside вҶҘP.
  haveI hNn : (L.subgroupOf P).Normal := hLn.subgroupOf P
  have hcardN : Nat.card (L.subgroupOf P) = Nat.card L :=
    Nat.card_congr (Subgroup.subgroupOfEquivOfLe hLP).toEquiv
  have hNidx : (L.subgroupOf P).index = Nat.card M := by
    have hmul := Subgroup.card_mul_index (L.subgroupOf P)
    rw [hcardN, hcardP_eq] at hmul
    exact Nat.eq_of_mul_eq_mul_left Nat.card_pos hmul
  have hcop : Nat.Coprime (Nat.card (L.subgroupOf P)) (L.subgroupOf P).index := by
    rw [hcardN, hNidx]; exact hMcop
  obtain вҹЁK, hKвҹ© := Subgroup.exists_right_complement'_of_coprime hcop
  set Ntil := K.map P.subtype with hNtil
  have hNleP : Ntil вүӨ P := Subgroup.map_subtype_le K
  have hLeq : (L.subgroupOf P).map P.subtype = L := Subgroup.map_subgroupOf_eq_of_le hLP
  have hmaptop : Subgroup.map P.subtype вҠӨ = P := by
    rw [вҶҗ MonoidHom.range_eq_map]; exact P.range_subtype
  have hcardK : Nat.card K = Nat.card M := by
    have hcm := hK.card_mul
    rw [hcardN, hcardP_eq] at hcm
    exact Nat.eq_of_mul_eq_mul_left Nat.card_pos hcm
  refine вҹЁNtil, hNleP, ?_, ?_, ?_вҹ©
  В· -- Ntil вҠ“ L = вҠҘ
    rw [hNtil, вҶҗ hLeq, вҶҗ Subgroup.map_inf K (L.subgroupOf P) P.subtype P.subtype_injective,
      inf_comm, disjoint_iff.mp hK.disjoint, Subgroup.map_bot]
  В· -- Ntil вҠ” L = P
    have hthis := congrArg (Subgroup.map P.subtype) hK.sup_eq_top
    rw [Subgroup.map_sup, hLeq, hmaptop] at hthis
    rw [hNtil, sup_comm]; exact hthis
  В· -- card Ntil = card M
    rw [hNtil, вҶҗ Nat.card_congr
      (Subgroup.equivMapOfInjective K P.subtype P.subtype_injective).toEquiv, hcardK]

open scoped Pointwise commutatorElement in
/-- **Lemma 9.2 (structure).** For a marked target `1 вҶ’ L вҶ’ Y вҶ’ H вҶ’ 1` with `L = ker ПҖ` a
2-group *scalar stack* and `H` 2-nilpotent (`M = OВІH` odd, `H/M` a 2-group), there is a unique
odd normal complement `Г‘ в—Ғ Y` to `L` over `M`: `Г‘` is odd, `Y/Г‘` is a 2-group, `Г‘ вҲ© L = вҠҘ`,
`Г‘` centralizes `L`, `ПҖ(Г‘) = M`, and `Г‘ В· L = ПҖвҒ»В№(M)`.  These are the fibre-product pieces
feeding `coprime_fiber_product` in the В§9 induction. -/
theorem lemma_9_2_core {H Y : Type} [Group H] [Group Y] [Finite Y]
    (piY : Y вҶ’* H) (hpi : Function.Surjective piY)
    (L : Subgroup Y) (hkerL : piY.ker = L) (hL2 : IsPGroup 2 L)
    (hstack : SectionSeven.IsScalarStack L)
    (M : Subgroup H) [M.Normal] (hModd : Odd (Nat.card M)) (hMtwo : IsPGroup 2 (H в§ё M)) :
    вҲғ Ntil : Subgroup Y, вҲғ _ : Ntil.Normal, Odd (Nat.card Ntil) вҲ§ IsPGroup 2 (Y в§ё Ntil) вҲ§
      Ntil вҠ“ L = вҠҘ вҲ§ вҒ…Ntil, LвҒҶ = вҠҘ вҲ§ Ntil.map piY = M вҲ§ Ntil вҠ” L = M.comap piY := by
  haveI : Finite H := Finite.of_surjective piY hpi
  haveI : Fact (Nat.Prime 2) := вҹЁNat.prime_twoвҹ©
  haveI hLn : L.Normal := hkerL в–ё piY.normal_ker
  haveI hMcn : (M.comap piY).Normal := вҖ№M.NormalвҖә.comap piY
  -- card L (a 2-power) is coprime to card M (odd)
  have hcop : Nat.Coprime (Nat.card L) (Nat.card M) := by
    obtain вҹЁk, hkвҹ© := hL2.exists_card_eq
    rw [hk]
    have hnd : В¬ (2 : в„•) вҲЈ Nat.card M := by have := Nat.odd_iff.mp hModd; omega
    exact (Nat.prime_two.coprime_iff_not_dvd.mpr hnd).pow_left k
  obtain вҹЁNtil, hNleP, hNL_bot, hNL_sup, hcardNtilвҹ© := sz_odd_complement piY hpi L hkerL M hcop
  -- `Г‘` centralizes `L` (odd group on a scalar stack)
  have hcentral : вҒ…Ntil, LвҒҶ = вҠҘ :=
    scalarStack_centralized_of_coprime hstack (by rw [hcardNtil]; exact hcop.symm)
  -- every element of `P = Г‘В·L` factors as `ГұВ·в„“`
  have hdecomp : вҲҖ p вҲҲ Ntil вҠ” L, вҲғ Гұ вҲҲ Ntil, вҲғ в„“ вҲҲ L, Гұ * в„“ = p := by
    intro p hp
    have hp' : p вҲҲ (Ntil : Set Y) * (L : Set Y) := by
      rw [вҶҗ Subgroup.mul_normal Ntil L]; exact hp
    rw [Set.mem_mul] at hp'
    obtain вҹЁГұ, hГұ, в„“, hв„“, hprodвҹ© := hp'
    exact вҹЁГұ, hГұ, в„“, hв„“, hprodвҹ©
  -- order in a subgroup equals order in `Y`
  have hoc : вҲҖ (S : Subgroup Y) (x : Y) (hx : x вҲҲ S), orderOf (вҹЁx, hxвҹ© : S) = orderOf x :=
    fun S x hx => (orderOf_injective S.subtype Subtype.coe_injective вҹЁx, hxвҹ©).symm
  -- the characterisation: `Г‘` = the odd-order elements of `P`
  have hkey : вҲҖ p : Y, p вҲҲ Ntil вҠ” L вҶ’ Odd (orderOf p) вҶ’ p вҲҲ Ntil := by
    intro p hpsup hpodd
    obtain вҹЁГұ, hГұ, в„“, hв„“, hprodвҹ© := hdecomp p hpsup
    have hcomm : Commute Гұ в„“ := by
      have h1 : вҒ…Гұ, в„“вҒҶ вҲҲ вҒ…Ntil, LвҒҶ := Subgroup.commutator_mem_commutator hГұ hв„“
      rw [hcentral, Subgroup.mem_bot] at h1
      exact commutatorElement_eq_one_iff_commute.mp h1
    have hГұdvd : orderOf Гұ вҲЈ Nat.card M := by
      rw [вҶҗ hcardNtil, вҶҗ hoc Ntil Гұ hГұ]; exact orderOf_dvd_natCard _
    have hв„“dvd : orderOf в„“ вҲЈ Nat.card L := by
      rw [вҶҗ hoc L в„“ hв„“]; exact orderOf_dvd_natCard _
    have hcopГұв„“ : Nat.Coprime (orderOf Гұ) (orderOf в„“) :=
      (hcop.symm.coprime_dvd_left hГұdvd).coprime_dvd_right hв„“dvd
    have hordp : orderOf p = orderOf Гұ * orderOf в„“ := by
      rw [вҶҗ hprod]; exact hcomm.orderOf_mul_eq_mul_orderOf_of_coprime hcopГұв„“
    rw [hordp] at hpodd
    have hв„“odd : Odd (orderOf в„“) := (Nat.odd_mul.mp hpodd).2
    obtain вҹЁj, hjвҹ© := IsPGroup.iff_orderOf.mp hL2 вҹЁв„“, hв„“вҹ©
    rw [hoc L в„“ hв„“] at hj
    rw [hj] at hв„“odd
    have hj0 : j = 0 := by
      by_contra hjne
      have h2d : 2 вҲЈ 2 ^ j := dvd_pow_self 2 hjne
      have := Nat.odd_iff.mp hв„“odd
      omega
    have hв„“1 : в„“ = 1 := orderOf_eq_one_iff.mp (by rw [hj, hj0, pow_zero])
    rw [вҶҗ hprod, hв„“1, mul_one]; exact hГұ
  -- normality of `Г‘` in `Y`
  have hNn : Ntil.Normal := by
    refine вҹЁfun n hn y => ?_вҹ©
    apply hkey
    В· rw [hNL_sup]; exact hMcn.conj_mem n (hNL_sup в–ё Subgroup.mem_sup_left hn) y
    В· have hconj : orderOf (y * n * yвҒ»В№) = orderOf n := by
        have h := orderOf_injective (MulAut.conj y).toMonoidHom (MulAut.conj y).injective n
        simpa [MulAut.conj_apply] using h
      rw [hconj]
      exact odd_of_dvd (by rw [вҶҗ hcardNtil, вҶҗ hoc Ntil n hn]; exact orderOf_dvd_natCard _) hModd
  -- `ПҖ(Г‘) = M`
  have hmapM : Ntil.map piY = M := by
    apply le_antisymm (Subgroup.map_le_iff_le_comap.mpr hNleP)
    intro m hm
    obtain вҹЁy, rflвҹ© := hpi m
    have hyP : y вҲҲ Ntil вҠ” L := by rw [hNL_sup]; exact Subgroup.mem_comap.mpr hm
    obtain вҹЁГұ, hГұ, в„“, hв„“, hprodвҹ© := hdecomp y hyP
    have hpiy : piY y = piY Гұ := by
      rw [вҶҗ hprod, map_mul, show piY в„“ = 1 from (MonoidHom.mem_ker.mp (hkerL в–ё hв„“)), mul_one]
    rw [hpiy]; exact Subgroup.mem_map.mpr вҹЁГұ, hГұ, rflвҹ©
  -- `Y/Г‘` is a 2-group
  haveI := hNn
  obtain вҹЁkL, hkLвҹ© := hL2.exists_card_eq
  obtain вҹЁkH, hkHвҹ© := hMtwo.exists_card_eq
  have hLindex2 : L.index = Nat.card H := by
    rw [Subgroup.index_eq_card, вҶҗ hkerL]
    exact Nat.card_congr (QuotientGroup.quotientKerEquivOfSurjective piY hpi).toEquiv
  have hcardYLH : Nat.card L * Nat.card H = Nat.card Y := by
    rw [вҶҗ hLindex2]; exact Subgroup.card_mul_index L
  have hcardHM : Nat.card M * Nat.card (H в§ё M) = Nat.card H := by
    rw [вҶҗ Subgroup.index_eq_card]; exact Subgroup.card_mul_index M
  have hNtilindex : Ntil.index = 2 ^ kL * 2 ^ kH := by
    have hci : Nat.card Ntil * Ntil.index = Nat.card Y := Subgroup.card_mul_index Ntil
    rw [hcardNtil, вҶҗ hcardYLH, вҶҗ hcardHM, hkL, hkH] at hci
    have hre : 2 ^ kL * (Nat.card M * 2 ^ kH) = Nat.card M * (2 ^ kL * 2 ^ kH) := by ring
    rw [hre] at hci
    exact Nat.eq_of_mul_eq_mul_left Nat.card_pos hci
  have hYNtil2 : IsPGroup 2 (Y в§ё Ntil) :=
    IsPGroup.of_card (n := kL + kH) (by rw [вҶҗ Subgroup.index_eq_card, hNtilindex, pow_add])
  exact вҹЁNtil, hNn, by rw [hcardNtil]; exact hModd, hYNtil2, hNL_bot, hcentral, hmapM, hNL_supвҹ©

/-- **The head of a boundary-framed target is 2-nilpotent.**  `H` is a finite tame quotient
`Оұ : Ttame вҶ  H` (the frame `Оұ`), so its generators `Оұ Пғ, Оұ П„` satisfy the tame relation and
generate `H`; `tame_two_nilpotent` applies.  This discharges the `M` hypothesis of
`lemma_9_2_core` from the frame. -/
theorem head_two_nilpotent {H E : Type} [Group H] [TopologicalSpace H] [DiscreteTopology H]
    [Finite H] [CommGroup E] [TopologicalSpace E] [DiscreteTopology E] [Finite E]
    (F : BoundaryFrame H E) :
    вҲғ M : Subgroup H, вҲғ _ : M.Normal, Odd (Nat.card M) вҲ§ IsPGroup 2 (H в§ё M) := by
  have hgen : Subgroup.closure {F.alpha tameSigma, F.alpha tameTau} = вҠӨ :=
    GQ2.SectionThree.gen_ttame_quotient F.alpha.toMonoidHom F.alpha.continuous_toFun
      F.alpha_surjective
  have hrel : (F.alpha tameSigma)вҒ»В№ * F.alpha tameTau * F.alpha tameSigma
      = (F.alpha tameTau) ^ 2 := by
    have h := congrArg (вҮ‘F.alpha) tame_relation
    rw [conjP, map_mul, map_mul, map_inv, map_pow] at h
    exact h
  exact tame_two_nilpotent hgen hrel

/-! ## Lemma 9.2 fibre-product infrastructure

The concrete tools the (144) correspondence runs on, all proved std-3:

* `odd_subgroup_le_ker_of_expTwo` вҖ” `Оё_Y` (decoration to the exponent-2 group `E`) kills the odd
  complement `Г‘`, so it descends to `Q = Y/Г‘` (`L92.thetaBarQ`).  This is where `hE2` enters.
* `odd_mem_of_pTwo_quotient` вҖ” an odd-order element dies in a 2-group quotient (вҹ№ `HвӮӮ = H/OВІH`
  is cyclic, the engine of source-independence).
* `L92` вҖ” a bundle of the `lemma_9_2_core` outputs; `L92.fibreMulEquiv` is the fibre-product
  isomorphism `Y вүғ* {(h,q) | Оә h = О» q}` (eq. (143)), built from `coprime_fiber_product`.

Remaining for `terminal_count_eq` (the В§9 induction): the boundary-lift вҶ” Q-count bijection (two more
`coprime_fiber_product` applications for surjectivity) and source-independence of the Q-count
(the HвӮӮ-values factor through `ОҪ_t`, so `compatA`/`compatF` make the two sources agree). -/

/-- **Оё kills the odd complement.**  A homomorphism from a finite group to an exponent-2 group
vanishes on every odd-order normal subgroup.  (This is where `hE2` enters the terminal case:
`Оё_Y` descends to `Q = Y/Г‘`.) -/
theorem odd_subgroup_le_ker_of_expTwo {Y E : Type} [Group Y] [Finite Y] [Group E]
    {N : Subgroup Y} (hodd : Odd (Nat.card N)) (hE2 : вҲҖ e : E, e ^ 2 = 1) (Оё : Y вҶ’* E) :
    N вүӨ Оё.ker := by
  intro n hn
  rw [MonoidHom.mem_ker]
  have hno : Odd (orderOf n) := by
    have h1 : orderOf (вҹЁn, hnвҹ© : N) вҲЈ Nat.card N := orderOf_dvd_natCard _
    have h2 : orderOf (вҹЁn, hnвҹ© : N) = orderOf n :=
      (orderOf_injective N.subtype Subtype.coe_injective вҹЁn, hnвҹ©).symm
    rw [h2] at h1
    exact odd_of_dvd h1 hodd
  have hd2 : orderOf (Оё n) вҲЈ 2 := orderOf_dvd_of_pow_eq_one (hE2 (Оё n))
  have hdn : orderOf (Оё n) вҲЈ orderOf n := orderOf_map_dvd Оё n
  have hodd' : Odd (orderOf (Оё n)) := odd_of_dvd hdn hno
  rcases (Nat.dvd_prime Nat.prime_two).mp hd2 with h | h
  В· exact orderOf_eq_one_iff.mp h
  В· exact absurd (h в–ё hodd') (by decide)


/-- Bundle of the `lemma_9_2_core` outputs, to avoid threading a dozen hypotheses through the
fibre-product construction. -/
structure L92 (H Y : Type) [Group H] [Group Y] [Finite Y] where
  piY : Y вҶ’* H
  hpi : Function.Surjective piY
  L : Subgroup Y
  hkerL : piY.ker = L
  M : Subgroup H
  hMn : M.Normal
  hModd : Odd (Nat.card M)
  Ntil : Subgroup Y
  hNn : Ntil.Normal
  hNodd : Odd (Nat.card Ntil)
  hNL : Ntil вҠ“ L = вҠҘ
  hmapM : Ntil.map piY = M
  hNLsup : Ntil вҠ” L = M.comap piY
  hQ2 : IsPGroup 2 (Y в§ё Ntil)

namespace L92

variable {H Y : Type} [Group H] [Group Y] [Finite Y] (D : L92 H Y)

/-- `Q = Y / Г‘`. -/
abbrev Q := Y в§ё D.Ntil

instance : (D.Ntil).Normal := D.hNn
instance : (D.M).Normal := D.hMn

/-- `Ntil вүӨ ker (Оә вҲҳ ПҖ_Y) = ПҖ_YвҒ»В№(M)`. -/
theorem ntil_le_ker : D.Ntil вүӨ ((QuotientGroup.mk' D.M).comp D.piY).ker := by
  intro n hn
  rw [MonoidHom.mem_ker, MonoidHom.comp_apply, QuotientGroup.mk'_apply,
    QuotientGroup.eq_one_iff]
  have : n вҲҲ D.M.comap D.piY := D.hNLsup в–ё Subgroup.mem_sup_left hn
  exact Subgroup.mem_comap.mp this

/-- The lower map `О» : Q вҶ  H/M`, descending `Оә вҲҳ ПҖ_Y`. -/
noncomputable def lamQ : D.Q вҶ’* H в§ё D.M :=
  QuotientGroup.lift D.Ntil ((QuotientGroup.mk' D.M).comp D.piY) D.ntil_le_ker

@[simp] private theorem lamQ_mk (y : Y) :
    D.lamQ (QuotientGroup.mk y) = QuotientGroup.mk' D.M (D.piY y) := rfl

/-- The fibre product `{(h,q) | Оә h = О» q} вүӨ H Г— Q`. -/
noncomputable def fibreSub : Subgroup (H Г— D.Q) :=
  MonoidHom.eqLocus ((QuotientGroup.mk' D.M).comp (MonoidHom.fst H D.Q))
    (D.lamQ.comp (MonoidHom.snd H D.Q))

/-- `(ПҖ_Y y, mk' Ntil y)` lands in the fibre product. -/
theorem toFibre_mem (y : Y) : (D.piY y, (QuotientGroup.mk y : D.Q)) вҲҲ D.fibreSub := by
  show (QuotientGroup.mk' D.M) (D.piY y) = D.lamQ (QuotientGroup.mk y)
  rw [lamQ_mk]

/-- The map `Y вҶ’ fibre product`, `y вҶҰ (ПҖ_Y y, mk' Ntil y)`. -/
noncomputable def toFibre : Y вҶ’* D.fibreSub :=
  (D.piY.prod (QuotientGroup.mk' D.Ntil)).codRestrict _ D.toFibre_mem

private theorem toFibre_injective : Function.Injective D.toFibre := by
  rw [injective_iff_map_eq_one]
  intro y hy
  have h1 : (D.piY y, (QuotientGroup.mk y : D.Q)) = 1 := by
    have := congrArg (Subtype.val) hy
    simpa [toFibre, MonoidHom.codRestrict] using this
  rw [Prod.ext_iff] at h1
  obtain вҹЁhyH, hyQвҹ© := h1
  have hyL : y вҲҲ D.L := D.hkerL в–ё MonoidHom.mem_ker.mpr hyH
  have hyN : y вҲҲ D.Ntil := by rwa [вҶҗ QuotientGroup.eq_one_iff]
  have : y вҲҲ D.Ntil вҠ“ D.L := вҹЁhyN, hyLвҹ©
  rw [D.hNL, Subgroup.mem_bot] at this
  exact this

private theorem lamQ_surjective : Function.Surjective D.lamQ := by
  intro z
  obtain вҹЁy, hyвҹ© := (QuotientGroup.mk'_surjective D.M).comp D.hpi z
  exact вҹЁQuotientGroup.mk y, by rw [lamQ_mk]; exact hyвҹ©

private theorem toFibre_surjective : Function.Surjective D.toFibre := by
  haveI : Finite H := Finite.of_surjective D.piY D.hpi
  have hcop : Nat.Coprime (Nat.card (QuotientGroup.mk' D.M).ker) (Nat.card D.lamQ.ker) := by
    rw [QuotientGroup.ker_mk']
    have hpg : IsPGroup 2 (D.lamQ.ker) := fun x => by
      obtain вҹЁk, hkвҹ© := D.hQ2 (x : D.Q)
      exact вҹЁk, by ext1; push_cast; exact hkвҹ©
    obtain вҹЁk, hkвҹ© := hpg.exists_card_eq
    rw [hk]
    have hnd : В¬ (2 : в„•) вҲЈ Nat.card D.M := by have := Nat.odd_iff.mp D.hModd; omega
    exact ((Nat.prime_two.coprime_iff_not_dvd.mpr hnd).symm).pow_right k
  set J := (D.piY.prod (QuotientGroup.mk' D.Ntil)).range with hJdef
  have hJsub : вҲҖ p вҲҲ J, (QuotientGroup.mk' D.M) p.1 = D.lamQ p.2 := by
    rintro p вҹЁy, rflвҹ©
    show (QuotientGroup.mk' D.M) (D.piY y) = D.lamQ (QuotientGroup.mk y)
    rw [lamQ_mk]
  have hJA : Function.Surjective fun p : J => (p : H Г— D.Q).1 := by
    intro h; obtain вҹЁy, hyвҹ© := D.hpi h
    exact вҹЁвҹЁ(D.piY y, QuotientGroup.mk y), y, rflвҹ©, hyвҹ©
  have hJB : Function.Surjective fun p : J => (p : H Г— D.Q).2 := by
    intro q; obtain вҹЁy, hyвҹ© := QuotientGroup.mk'_surjective D.Ntil q
    exact вҹЁвҹЁ(D.piY y, QuotientGroup.mk y), y, rflвҹ©, hyвҹ©
  intro p
  have hp : (QuotientGroup.mk' D.M) (p : H Г— D.Q).1 = D.lamQ (p : H Г— D.Q).2 := p.2
  have hmem : (p : H Г— D.Q) вҲҲ J :=
    GQ2.FiniteGroup.coprime_fiber_product (QuotientGroup.mk' D.M) D.lamQ
      (QuotientGroup.mk'_surjective _) D.lamQ_surjective hcop J hJsub hJA hJB _ hp
  obtain вҹЁy, hyвҹ© := hmem
  exact вҹЁy, Subtype.ext hyвҹ©

/-- **The fibre-product isomorphism** `Y вүғ* {(h,q) | Оә h = О» q}` (Lemma 9.2, eq. (143)). -/
noncomputable def fibreMulEquiv : Y вүғ* D.fibreSub :=
  MulEquiv.ofBijective D.toFibre вҹЁD.toFibre_injective, D.toFibre_surjectiveвҹ©

@[simp] private theorem fibreMulEquiv_apply (y : Y) :
    (D.fibreMulEquiv y : H Г— D.Q) = (D.piY y, QuotientGroup.mk y) := rfl

/-- A decoration `Оё : Y вҶ’* E` to an exponent-2 group descends to `Q = Y/Г‘` (Оё kills odd `Г‘`). -/
noncomputable def thetaBarQ {E : Type} [Group E] (Оё : Y вҶ’* E) (hE2 : вҲҖ e : E, e ^ 2 = 1) :
    D.Q вҶ’* E :=
  QuotientGroup.lift D.Ntil Оё (odd_subgroup_le_ker_of_expTwo D.hNodd hE2 Оё)

@[simp] private theorem thetaBarQ_mk {E : Type} [Group E] (Оё : Y вҶ’* E) (hE2 : вҲҖ e : E, e ^ 2 = 1)
    (y : Y) : D.thetaBarQ Оё hE2 (QuotientGroup.mk y) = Оё y := rfl

end L92

/-! ## The (144) correspondence

Lemma 9.2's fibre product identifies the boundary-framed lifts `О“ вҶ  Y` with a Q-count set
(`boundaryLifts_equiv_qlifts`, source-generic); the maximal-pro-2 universal property then makes
that count source-independent (`qlifts_equiv_commonLifts`), routed through `ОҪ`-compatibility and
`b`-surjectivity вҖ” no marked isomorphism is needed (only `prop_3_10_gammaA` and `ker_pro2F`). -/

section Correspondence

open SectionThree
open scoped Pointwise

variable {Y : Type} [Group Y] [TopologicalSpace Y] [DiscreteTopology Y] [Finite Y]

namespace L92

variable (D : L92 H Y)

omit [TopologicalSpace H] [DiscreteTopology H] [Finite H] in
/-- `Q = Y/Г‘` is discrete (quotient of a discrete group by an open subgroup). -/
theorem discreteTopology_Q : DiscreteTopology D.Q :=
  QuotientGroup.discreteTopology (isOpen_discrete _)

omit [TopologicalSpace H] [DiscreteTopology H] [Finite H] [TopologicalSpace Y]
  [DiscreteTopology Y] in
private theorem piY_symm (z : D.fibreSub) : D.piY (D.fibreMulEquiv.symm z) = (z : H Г— D.Q).1 := by
  have h := D.fibreMulEquiv_apply (D.fibreMulEquiv.symm z)
  rw [MulEquiv.apply_symm_apply] at h
  exact ((Prod.ext_iff.mp h).1).symm

omit [TopologicalSpace H] [DiscreteTopology H] [Finite H] [TopologicalSpace Y]
  [DiscreteTopology Y] in
private theorem mk_symm (z : D.fibreSub) :
    (QuotientGroup.mk (D.fibreMulEquiv.symm z) : D.Q) = (z : H Г— D.Q).2 := by
  have h := D.fibreMulEquiv_apply (D.fibreMulEquiv.symm z)
  rw [MulEquiv.apply_symm_apply] at h
  exact ((Prod.ext_iff.mp h).2).symm

/-- The quotient map `Y вҶ  Q` as a continuous hom. -/
def mkCH : ContinuousMonoidHom Y D.Q := вҹЁQuotientGroup.mk' D.Ntil, continuous_quotient_mk'вҹ©

omit [TopologicalSpace H] [DiscreteTopology H] [Finite H] [DiscreteTopology Y] in
@[simp] private theorem mkCH_apply (y : Y) : D.mkCH y = (QuotientGroup.mk y : D.Q) := rfl

end L92

variable {О“ : Type} [Group О“] [TopologicalSpace О“]

/-- **The Q-count set**: continuous surjections `О“ вҶ  Q` satisfying the descended boundary
conditions (H-part through `О»`, Оё-part through `ОёМ„`). -/
def QLifts (F : BoundaryFrame H E) (T : MarkedTarget H E Y) (hE2 : вҲҖ e : E, e ^ 2 = 1)
    (D : L92 H Y) (b : ContinuousMonoidHom О“ вҶҘboundarySubgroup) : Type :=
  { g : ContSurj О“ D.Q //
    (вҲҖ Оі, D.lamQ (g.1 Оі) = QuotientGroup.mk' D.M (F.alpha (b Оі).val.1)) вҲ§
    (вҲҖ Оі, D.thetaBarQ T.thetaY hE2 (g.1 Оі) = F.psiBar (b Оі).val.2) }

/-- The reconstruction of a boundary lift `f : О“ вҶ  Y` from a Q-lift `g`, via the fibre product
`Y вү… H Г—_{HвӮӮ} Q`: `f Оі := fibreMulEquiv.symm (F.alpha (b Оі).1, g Оі)`. -/
noncomputable def qliftHom (F : BoundaryFrame H E) (D : L92 H Y)
    (b : ContinuousMonoidHom О“ вҶҘboundarySubgroup) (g : ContSurj О“ D.Q)
    (h1 : вҲҖ Оі, D.lamQ (g.1 Оі) = QuotientGroup.mk' D.M (F.alpha (b Оі).val.1)) :
    ContinuousMonoidHom О“ Y where
  toMonoidHom := D.fibreMulEquiv.symm.toMonoidHom.comp
    (((F.alpha.toMonoidHom.comp ((MonoidHom.fst Ttame PiBd).comp
      (boundarySubgroup.subtype.comp b.toMonoidHom))).prod g.1.toMonoidHom).codRestrict
      D.fibreSub (fun Оі => (h1 Оі).symm))
  continuous_toFun := by
    haveI hdQ : DiscreteTopology D.Q := D.discreteTopology_Q
    haveI : DiscreteTopology (H Г— D.Q) := inferInstance
    haveI : DiscreteTopology D.fibreSub := inferInstance
    have hПҶ : Continuous fun Оі : О“ =>
        (вҹЁ(F.alpha (b Оі).val.1, g.1 Оі), (h1 Оі).symmвҹ© : D.fibreSub) :=
      Continuous.subtype_mk ((F.alpha.continuous_toFun.comp (continuous_fst.comp
        (continuous_subtype_val.comp b.continuous_toFun))).prodMk g.1.continuous_toFun) _
    exact (continuous_of_discreteTopology (f := D.fibreMulEquiv.symm)).comp hПҶ

@[simp] private theorem qliftHom_piY (F : BoundaryFrame H E) (D : L92 H Y)
    (b : ContinuousMonoidHom О“ вҶҘboundarySubgroup) (g : ContSurj О“ D.Q)
    (h1 : вҲҖ Оі, D.lamQ (g.1 Оі) = QuotientGroup.mk' D.M (F.alpha (b Оі).val.1)) (Оі : О“) :
    D.piY (qliftHom F D b g h1 Оі) = F.alpha (b Оі).val.1 := by
  rw [qliftHom]
  exact D.piY_symm _

@[simp] private theorem qliftHom_mk (F : BoundaryFrame H E) (D : L92 H Y)
    (b : ContinuousMonoidHom О“ вҶҘboundarySubgroup) (g : ContSurj О“ D.Q)
    (h1 : вҲҖ Оі, D.lamQ (g.1 Оі) = QuotientGroup.mk' D.M (F.alpha (b Оі).val.1)) (Оі : О“) :
    (QuotientGroup.mk (qliftHom F D b g h1 Оі) : D.Q) = g.1 Оі := by
  rw [qliftHom]
  exact D.mk_symm _

/-- The reconstructed `f = qliftHom вҖҰ g` is **surjective** (the "second `coprime_fiber_product`":
the range of `(Оі вҶҰ (F.alpha (b Оі).1, g Оі))` is all of the fibre, since it projects onto both `H`
and `Q` which have coprime kernels).  Uses `hb` (surjectivity of `b`). -/
theorem qliftHom_surjective (F : BoundaryFrame H E) (D : L92 H Y)
    (b : ContinuousMonoidHom О“ вҶҘboundarySubgroup) (hb : Function.Surjective b)
    (g : ContSurj О“ D.Q)
    (h1 : вҲҖ Оі, D.lamQ (g.1 Оі) = QuotientGroup.mk' D.M (F.alpha (b Оі).val.1)) :
    Function.Surjective (qliftHom F D b g h1) := by
  haveI : Finite H := Finite.of_surjective D.piY D.hpi
  have hHsurj : Function.Surjective fun Оі : О“ => F.alpha (b Оі).val.1 := by
    intro h
    obtain вҹЁt, htвҹ© := F.alpha_surjective h
    obtain вҹЁp, hpвҹ© := nuTwo_surjective (nuT t)
    obtain вҹЁОі, hОівҹ© := hb вҹЁ(t, p), hp.symmвҹ©
    refine вҹЁОі, ?_вҹ©
    show F.alpha (b Оі).val.1 = h
    rw [hОі]; exact ht
  have hcop : Nat.Coprime (Nat.card (QuotientGroup.mk' D.M).ker) (Nat.card D.lamQ.ker) := by
    rw [QuotientGroup.ker_mk']
    have hpg : IsPGroup 2 (D.lamQ.ker) := fun x => by
      obtain вҹЁk, hkвҹ© := D.hQ2 (x : D.Q)
      exact вҹЁk, by ext1; push_cast; exact hkвҹ©
    obtain вҹЁk, hkвҹ© := hpg.exists_card_eq
    rw [hk]
    have hnd : В¬ (2 : в„•) вҲЈ Nat.card D.M := by have := Nat.odd_iff.mp D.hModd; omega
    exact ((Nat.prime_two.coprime_iff_not_dvd.mpr hnd).symm).pow_right k
  set hHomM : О“ вҶ’* H := F.alpha.toMonoidHom.comp ((MonoidHom.fst Ttame PiBd).comp
    (boundarySubgroup.subtype.comp b.toMonoidHom)) with hHomMdef
  set J := (hHomM.prod g.1.toMonoidHom).range with hJdef
  have hJsub : вҲҖ p вҲҲ J, (QuotientGroup.mk' D.M) p.1 = D.lamQ p.2 := by
    rintro p вҹЁОі, rflвҹ©
    exact (h1 Оі).symm
  have hJA : Function.Surjective fun p : J => (p : H Г— D.Q).1 := by
    intro h
    obtain вҹЁОі, hОівҹ© := hHsurj h
    exact вҹЁвҹЁ(hHomM Оі, g.1 Оі), Оі, rflвҹ©, hОівҹ©
  have hJB : Function.Surjective fun p : J => (p : H Г— D.Q).2 := by
    intro q
    obtain вҹЁОі, hОівҹ© := g.2 q
    exact вҹЁвҹЁ(hHomM Оі, g.1 Оі), Оі, rflвҹ©, hОівҹ©
  intro y
  have hz : (QuotientGroup.mk' D.M) (D.fibreMulEquiv y : H Г— D.Q).1
      = D.lamQ (D.fibreMulEquiv y : H Г— D.Q).2 := (D.fibreMulEquiv y).2
  obtain вҹЁОі, hОівҹ© := GQ2.FiniteGroup.coprime_fiber_product (QuotientGroup.mk' D.M) D.lamQ
    (QuotientGroup.mk'_surjective _) D.lamQ_surjective hcop J hJsub hJA hJB _ hz
  refine вҹЁОі, D.fibreMulEquiv.injective (Subtype.ext ?_)вҹ©
  rw [D.fibreMulEquiv_apply, qliftHom_piY, qliftHom_mk]
  exact hОі

/-- **Forward map** of the (144) correspondence: a boundary lift `f : О“ вҶ  Y` descends to the
Q-lift `mk вҲҳ f`. -/
def blToQ (F : BoundaryFrame H E) (T : MarkedTarget H E Y) (hE2 : вҲҖ e : E, e ^ 2 = 1)
    (D : L92 H Y) (hDpi : D.piY = T.piY) (b : ContinuousMonoidHom О“ вҶҘboundarySubgroup)
    (x : BoundaryLifts b F T) : QLifts F T hE2 D b := by
  refine вҹЁвҹЁD.mkCH.comp x.1.1, (QuotientGroup.mk'_surjective _).comp x.1.2вҹ©, ?_, ?_вҹ©
  В· intro Оі
    have hbl : T.piY (x.1.1 Оі) = F.alpha (b Оі).val.1 := congrArg Prod.fst (x.2 Оі)
    show D.lamQ (D.mkCH (x.1.1 Оі)) = QuotientGroup.mk' D.M (F.alpha (b Оі).val.1)
    rw [D.mkCH_apply, D.lamQ_mk, hDpi, hbl]
  В· intro Оі
    have hbl : T.thetaY (x.1.1 Оі) = F.psiBar (b Оі).val.2 := congrArg Prod.snd (x.2 Оі)
    show D.thetaBarQ T.thetaY hE2 (D.mkCH (x.1.1 Оі)) = F.psiBar (b Оі).val.2
    rw [D.mkCH_apply, D.thetaBarQ_mk, hbl]

/-- **Backward map** of the (144) correspondence: a Q-lift `g` reconstructs the boundary lift
`qliftHom вҖҰ g` via the fibre product. -/
noncomputable def qToBl (F : BoundaryFrame H E) (T : MarkedTarget H E Y)
    (hE2 : вҲҖ e : E, e ^ 2 = 1) (D : L92 H Y) (hDpi : D.piY = T.piY)
    (b : ContinuousMonoidHom О“ вҶҘboundarySubgroup)
    (hb : Function.Surjective b) (g : QLifts F T hE2 D b) : BoundaryLifts b F T := by
  refine вҹЁвҹЁqliftHom F D b g.1 g.2.1, qliftHom_surjective F D b hb g.1 g.2.1вҹ©, fun Оі => ?_вҹ©
  refine Prod.ext ?_ ?_
  В· show T.piY (qliftHom F D b g.1 g.2.1 Оі) = F.alpha (b Оі).val.1
    rw [вҶҗ hDpi, qliftHom_piY]
  В· show T.thetaY (qliftHom F D b g.1 g.2.1 Оі) = F.psiBar (b Оі).val.2
    rw [вҶҗ D.thetaBarQ_mk T.thetaY hE2, qliftHom_mk]
    exact g.2.2 Оі

/-- **(A) The (144) correspondence** (source-generic): the boundary-framed lifts `О“ вҶ  Y` and the
Q-count set are in bijection, hence equinumerous.  Uses only surjectivity of `b`. -/
theorem boundaryLifts_equiv_qlifts (F : BoundaryFrame H E) (T : MarkedTarget H E Y)
    (hE2 : вҲҖ e : E, e ^ 2 = 1) (D : L92 H Y) (hDpi : D.piY = T.piY)
    (b : ContinuousMonoidHom О“ вҶҘboundarySubgroup) (hb : Function.Surjective b) :
    Nat.card (BoundaryLifts b F T) = Nat.card (QLifts F T hE2 D b) := by
  apply Nat.card_congr
  refine вҹЁblToQ F T hE2 D hDpi b, qToBl F T hE2 D hDpi b hb, fun x => ?_, fun g => ?_вҹ©
  В· -- left_inv
    apply Subtype.ext; apply Subtype.ext
    show qliftHom F D b (blToQ F T hE2 D hDpi b x).1 (blToQ F T hE2 D hDpi b x).2.1 = x.1.1
    ext Оі
    have hpi : F.alpha (b Оі).val.1 = D.piY (x.1.1 Оі) := by
      rw [hDpi]; exact (congrArg Prod.fst (x.2 Оі)).symm
    apply D.fibreMulEquiv.injective; apply Subtype.ext
    simp only [D.fibreMulEquiv_apply, qliftHom_piY, qliftHom_mk]
    exact Prod.ext hpi rfl
  В· -- right_inv
    apply Subtype.ext; apply Subtype.ext; ext Оі
    exact qliftHom_mk F D b g.1 g.2.1 Оі

end Correspondence

section SourceIndependence

open SectionThree

/-- Precomposition with a topological iso is an equivalence of hom-sets. -/
def precompEquiv {A B Q : Type*} [Group A] [TopologicalSpace A] [Group B] [TopologicalSpace B]
    [Group Q] [TopologicalSpace Q] (ПҒ : ContinuousMulEquiv A B) :
    ContinuousMonoidHom B Q вүғ ContinuousMonoidHom A Q where
  toFun ПҲ := ПҲ.comp вҹЁПҒ.toMonoidHom, ПҒ.continuous_toFunвҹ©
  invFun ПҶ := ПҶ.comp вҹЁПҒ.symm.toMonoidHom, ПҒ.symm.continuous_toFunвҹ©
  left_inv ПҲ := by
    ext b
    exact congrArg ПҲ (ПҒ.apply_symm_apply b)
  right_inv ПҶ := by
    ext a
    exact congrArg ПҶ (ПҒ.symm_apply_apply a)

variable {О“ : Type} [Group О“] [TopologicalSpace О“] [IsTopologicalGroup О“]
  [CompactSpace О“] [T2Space О“] [TotallyDisconnectedSpace О“]

/-- The factoring of `pro2 : О“ вҶ  О ` through the maximal pro-2 quotient of `О“`
(`О ` is pro-2, `isProP_maxProPQuotient`). -/
noncomputable def pro2FactorHom (pro2 : ContinuousMonoidHom О“ PiBd) :
    ContinuousMonoidHom (maxProPQuotient 2 О“) PiBd :=
  (maxProPHomEquiv (isProP_maxProPQuotient (G := profinitePresentation {piRelator}))).symm pro2

omit [T2Space О“] in
private theorem pro2FactorHom_maxProPMk (pro2 : ContinuousMonoidHom О“ PiBd) (Оі : О“) :
    pro2FactorHom pro2 (maxProPMk 2 О“ Оі) = pro2 Оі :=
  DFunLike.congr_fun ((maxProPHomEquiv
    (isProP_maxProPQuotient (G := profinitePresentation {piRelator}))).apply_symm_apply pro2) Оі

/-- The maximal pro-2 quotient of `О“` is `О ` (`PiBd`), via a pro-2 quotient map `pro2` whose
kernel is exactly `proPKernel 2 О“`. -/
noncomputable def pro2Iso (pro2 : ContinuousMonoidHom О“ PiBd) (hsurj : Function.Surjective pro2)
    (hker : pro2.toMonoidHom.ker = proPKernel 2 О“) :
    ContinuousMulEquiv (maxProPQuotient 2 О“) PiBd :=
  continuousMulEquivOfBijective (pro2FactorHom pro2)
    вҹЁby
        rw [injective_iff_map_eq_one]
        intro x hx
        obtain вҹЁОі, rflвҹ© := quotientMk_surjective (proPKernel 2 О“) x
        have hx' : pro2 Оі = 1 := by rw [вҶҗ pro2FactorHom_maxProPMk pro2 Оі]; exact hx
        exact (quotientMk_eq_one_iff _).mpr (hker в–ё MonoidHom.mem_ker.mpr hx'),
      fun p => by
        obtain вҹЁОі, rflвҹ© := hsurj p
        exact вҹЁmaxProPMk 2 О“ Оі, pro2FactorHom_maxProPMk pro2 Оівҹ©вҹ©

omit [T2Space О“] in
private theorem pro2Iso_maxProPMk (pro2 : ContinuousMonoidHom О“ PiBd) (hsurj : Function.Surjective pro2)
    (hker : pro2.toMonoidHom.ker = proPKernel 2 О“) (Оі : О“) :
    pro2Iso pro2 hsurj hker (maxProPMk 2 О“ Оі) = pro2 Оі :=
  pro2FactorHom_maxProPMk pro2 Оі

/-- **Precomposition with the pro-2 quotient map** is a bijection of hom-sets into a pro-2 group
`Q`: every `g : О“ вҶ  Q` factors uniquely through `О `.  (The universal property of the maximal
pro-2 quotient, transported to `О `.) -/
noncomputable def compPro2Equiv (pro2 : ContinuousMonoidHom О“ PiBd)
    (hsurj : Function.Surjective pro2) (hker : pro2.toMonoidHom.ker = proPKernel 2 О“)
    {Q : Type} [Group Q] [TopologicalSpace Q] [IsTopologicalGroup Q] [CompactSpace Q] [T2Space Q]
    [TotallyDisconnectedSpace Q] (hQ : IsProP 2 Q) :
    ContinuousMonoidHom PiBd Q вүғ ContinuousMonoidHom О“ Q :=
  (precompEquiv (pro2Iso pro2 hsurj hker)).trans (maxProPHomEquiv hQ)

omit [T2Space О“] in
private theorem compPro2Equiv_apply_apply (pro2 : ContinuousMonoidHom О“ PiBd)
    (hsurj : Function.Surjective pro2) (hker : pro2.toMonoidHom.ker = proPKernel 2 О“)
    {Q : Type} [Group Q] [TopologicalSpace Q] [IsTopologicalGroup Q] [CompactSpace Q] [T2Space Q]
    [TotallyDisconnectedSpace Q] (hQ : IsProP 2 Q) (ПҲ : ContinuousMonoidHom PiBd Q) (Оі : О“) :
    compPro2Equiv pro2 hsurj hker hQ ПҲ Оі = ПҲ (pro2 Оі) := by
  show ПҲ (pro2Iso pro2 hsurj hker (maxProPMk 2 О“ Оі)) = ПҲ (pro2 Оі)
  rw [pro2Iso_maxProPMk]

variable {Y : Type} [Group Y] [TopologicalSpace Y] [DiscreteTopology Y] [Finite Y]

/-- **The common Q-count set on `О `** (source-free): the H-condition is indexed by `вҲӮbd`
(so it never mentions a source), the Оё-condition ranges over all of `О `. -/
def CommonLifts (F : BoundaryFrame H E) (T : MarkedTarget H E Y) (hE2 : вҲҖ e : E, e ^ 2 = 1)
    (D : L92 H Y) : Type :=
  { g : ContSurj PiBd D.Q //
    (вҲҖ x : вҶҘboundarySubgroup, D.lamQ (g.1 x.val.2) = QuotientGroup.mk' D.M (F.alpha x.val.1)) вҲ§
    (вҲҖ ПҖ : PiBd, D.thetaBarQ T.thetaY hE2 (g.1 ПҖ) = F.psiBar ПҖ) }

/-- **(B) Source-independence** (per source): the Q-count for a source `О“` (with pro-2 quotient
map `pro2` presenting `О `, `hker`) equals the source-free count on `О `.  The H-condition
transports through surjectivity of `b` (`hbpro2`: the pro-2 component of `b` is `pro2`); the
Оё-condition is already on `О `. -/
theorem qlifts_equiv_commonLifts (F : BoundaryFrame H E) (T : MarkedTarget H E Y)
    (hE2 : вҲҖ e : E, e ^ 2 = 1) (D : L92 H Y)
    {О“ : Type} [Group О“] [TopologicalSpace О“] [IsTopologicalGroup О“] [CompactSpace О“] [T2Space О“]
    [TotallyDisconnectedSpace О“] (b : ContinuousMonoidHom О“ вҶҘboundarySubgroup)
    (hb : Function.Surjective b) (pro2 : ContinuousMonoidHom О“ PiBd)
    (hpro2 : Function.Surjective pro2) (hbpro2 : вҲҖ Оі, (b Оі).val.2 = pro2 Оі)
    (hker : pro2.toMonoidHom.ker = proPKernel 2 О“) :
    Nat.card (QLifts F T hE2 D b) = Nat.card (CommonLifts F T hE2 D) := by
  haveI hdQ : DiscreteTopology D.Q := D.discreteTopology_Q
  haveI : Finite D.Q := inferInstance
  have hQ : IsProP 2 D.Q := isProP_of_isPGroup D.hQ2
  set E' := compPro2Equiv pro2 hpro2 hker hQ with hE'def
  have happly : вҲҖ (ПҲ : ContinuousMonoidHom PiBd D.Q) (Оі : О“), E' ПҲ Оі = ПҲ (pro2 Оі) := by
    intro ПҲ Оі; rw [hE'def]; exact compPro2Equiv_apply_apply pro2 hpro2 hker hQ ПҲ Оі
  apply Nat.card_congr
  refine вҹЁfun g => вҹЁвҹЁE'.symm g.1.1, ?_вҹ©, ?_, ?_вҹ©, fun g => вҹЁвҹЁE' g.1.1, ?_вҹ©, ?_, ?_вҹ©, ?_, ?_вҹ©
  В· -- toFun surjective
    intro q
    obtain вҹЁОі, hОівҹ© := g.1.2 q
    exact вҹЁpro2 Оі, by rw [вҶҗ happly (E'.symm g.1.1) Оі, E'.apply_symm_apply]; exact hОівҹ©
  В· -- toFun H-condition (indexed by вҲӮbd)
    intro x
    obtain вҹЁОі, hОівҹ© := hb x
    have hx1 : (E'.symm g.1.1) x.val.2 = g.1.1 Оі := by
      rw [show x.val.2 = pro2 Оі by rw [вҶҗ hОі]; exact hbpro2 Оі,
        вҶҗ happly (E'.symm g.1.1) Оі, E'.apply_symm_apply]
    rw [hx1, g.2.1 Оі, hОі]
  В· -- toFun Оё-condition (indexed by О )
    intro ПҖ
    obtain вҹЁОі, hОівҹ© := hpro2 ПҖ
    have hПҖ : (E'.symm g.1.1) ПҖ = g.1.1 Оі := by
      rw [вҶҗ hОі, вҶҗ happly (E'.symm g.1.1) Оі, E'.apply_symm_apply]
    rw [hПҖ, g.2.2 Оі, hbpro2 Оі, hОі]
  В· -- invFun surjective
    intro q
    obtain вҹЁПҖ, hПҖвҹ© := g.1.2 q
    obtain вҹЁОі, hОівҹ© := hpro2 ПҖ
    exact вҹЁОі, by rw [happly g.1.1 Оі, hОі]; exact hПҖвҹ©
  В· -- invFun H-condition (per Оі)
    intro Оі
    rw [happly g.1.1 Оі]
    have h := g.2.1 (b Оі)
    rw [hbpro2 Оі] at h
    exact h
  В· -- invFun Оё-condition (per Оі)
    intro Оі
    rw [happly g.1.1 Оі, g.2.2 (pro2 Оі), hbpro2 Оі]
  В· -- left_inv
    intro g; apply Subtype.ext; apply Subtype.ext; exact E'.apply_symm_apply g.1.1
  В· -- right_inv
    intro g; apply Subtype.ext; apply Subtype.ext; exact E'.symm_apply_apply g.1.1

end SourceIndependence

open SectionThree in
/-- `ker pro2A = proPKernel 2 О“_A` for any `BoundaryMaps` `B`: `pro2A` agrees with the
`prop_3_10_gammaA` isomorphism `e вҲҳ maxProPMk` on the four marked topological generators, hence
equals it, and `e` is injective. -/
theorem ker_pro2A (B : BoundaryMaps) :
    B.pro2A.toMonoidHom.ker = proPKernel 2 GammaA := by
  obtain вҹЁe, heПғ, heП„, hex0, hex1вҹ© := prop_3_10_gammaA
  set eHom : ContinuousMonoidHom GammaA PiBd :=
    (вҹЁe.toMonoidHom, e.continuous_toFunвҹ© :
      ContinuousMonoidHom (maxProPQuotient 2 GammaA) PiBd).comp (maxProPMk 2 GammaA) with heHom
  have heq : вҲҖ g, B.pro2A g = eHom g := by
    apply monoidHom_eq_of_topGen B.pro2A.continuous_toFun eHom.continuous_toFun topGen_gammaA
    rintro z (rfl | rfl | rfl | rfl)
    В· exact B.pro2A_sigma.trans heПғ.symm
    В· exact B.pro2A_tau.trans heП„.symm
    В· exact B.pro2A_x0.trans hex0.symm
    В· exact B.pro2A_x1.trans hex1.symm
  ext g
  constructor
  В· intro hg
    have hg1 : eHom g = 1 := by rw [вҶҗ heq g]; exact MonoidHom.mem_ker.mp hg
    have h2 : maxProPMk 2 GammaA g = 1 :=
      e.injective (by show e (maxProPMk 2 GammaA g) = e 1; rw [map_one]; exact hg1)
    exact (quotientMk_eq_one_iff (proPKernel 2 GammaA)).mp h2
  В· intro hg
    have h2 : maxProPMk 2 GammaA g = 1 := (quotientMk_eq_one_iff (proPKernel 2 GammaA)).mpr hg
    have h3 : eHom g = 1 := by show e (maxProPMk 2 GammaA g) = 1; rw [h2, map_one]
    exact MonoidHom.mem_ker.mpr (by show B.pro2A g = 1; rw [heq g]; exact h3)

end SectionNine

