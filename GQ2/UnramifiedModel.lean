import GQ2.DeepPart

/-!
# P-15f3: `prop_6_18_unramified` via the Hermitian-line model

The unramified case of Proposition 6.18 (eq. (115)): for a simple faithful `ùîΩ‚ÇÇ[C]`-module `V`
of cardinality `2^{2m}` at an **unramified** marking (`c tameTau` acts trivially), the base
determinant form `Q‚Å∞_loc` has the negative Gauss sign:
`#(Q‚Å∞_loc)‚Åª¬π(0) = 2^{2m‚àí1} ‚àí 2^{m‚àí1}`.

Unlike the ramified case (which routes through Lemma 6.17's self-perpendicularity + vanishing,
`GQ2.DeepPart.card_Q0loc_zero_eq_of_dim_of_vanish`, hardwired to the `+` sign), the unramified
minus-type count comes from the **Hermitian-line model**: `V` is identified with a finite field
`F = ùîΩ_{2^{2m}}` (Schur, `C` cyclic hence `ùîΩ‚ÇÇ[C]`-image a field), `H¬π(G_{‚Ñö‚ÇÇ}, V) ‚âÖ F` as an
`F`-line, and `Q‚Å∞_loc` transports to a nonsingular **norm-one-invariant** quadratic form on `F`,
whose zero-count is `2^{2m‚àí1} ‚àí 2^{m‚àí1}` by the model-free algebraic core
`GQ2.DeepPart.card_normOne_invariant_form_zero`.

This file lives downstream of `DeepPart` (which supplies `Q0loc`, the Euler collapse, the
Hermitian count, and `nonsingular_Q0loc`), so ‚Äî following the P-15d / 6.18-ramified pattern ‚Äî the
statement is **moved out** of `SectionSix.lean` (a pointer comment is left there); the fully
qualified name stays `GQ2.SectionSix.prop_6_18_unramified` is preserved by re-export.
-/

namespace GQ2

open ContCoh QuadraticFp2 Corestriction SectionSix DeepPart

open scoped Classical

namespace UnramifiedModel

/-! ## Coefficient functoriality of `mapCoeff1` (general ‚Äî belongs in the cohomology library)

`mapCoeff1` is functorial in the coefficient map: it sends `id` to `id` and `f ‚àò g` to
`mapCoeff1 f ‚àò mapCoeff1 g`.  These descend the corresponding cochain-level facts about `Z1comap`
through the `H¬π` quotient (`QuotientAddGroup.map_mk'`).  Needed to promote the coefficient action
of an abelian `C` on `V` to a `C`-action on `H¬π`. -/

section Functoriality

variable {G : Type*} [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
variable {M : Type*} [AddCommGroup M] [TopologicalSpace M] [IsTopologicalAddGroup M]
  [DistribMulAction G M] [ContinuousSMul G M]
variable {N : Type*} [AddCommGroup N] [TopologicalSpace N] [IsTopologicalAddGroup N]
  [DistribMulAction G N] [ContinuousSMul G N]
variable {P : Type*} [AddCommGroup P] [TopologicalSpace P] [IsTopologicalAddGroup P]
  [DistribMulAction G P] [ContinuousSMul G P]

/-- `mapCoeff1` on an explicit cocycle class post-composes the cocycle with `f`. -/
theorem mapCoeff1_H1mk (f : N ‚Üí+ M) (hf : Continuous f)
    (hcompat : ‚àÄ (g : G) (n : N), f (g ‚Ä¢ n) = g ‚Ä¢ f n) (z : Z1 G N) :
    mapCoeff1 f hf hcompat (H1mk G N z)
      = H1mk G M (Z1comap (ContinuousMonoidHom.id G) f hf (fun g n => hcompat g n) z) :=
  rfl

/-- `mapCoeff1 (id) = id`. -/
theorem mapCoeff1_id
    (hcompat : ‚àÄ (g : G) (m : M), (AddMonoidHom.id M) (g ‚Ä¢ m) = g ‚Ä¢ (AddMonoidHom.id M) m) :
    mapCoeff1 (AddMonoidHom.id M) continuous_id hcompat = AddMonoidHom.id (H1 G M) := by
  ext x
  induction x using QuotientAddGroup.induction_on with
  | _ z => rfl

/-- `mapCoeff1 (f ‚àò g) = mapCoeff1 f ‚àò mapCoeff1 g`. -/
theorem mapCoeff1_comp (f : N ‚Üí+ M) (hf : Continuous f)
    (hfc : ‚àÄ (g : G) (n : N), f (g ‚Ä¢ n) = g ‚Ä¢ f n)
    (e : P ‚Üí+ N) (he : Continuous e) (hec : ‚àÄ (g : G) (p : P), e (g ‚Ä¢ p) = g ‚Ä¢ e p) :
    mapCoeff1 (f.comp e) (hf.comp he) (fun g p => by rw [AddMonoidHom.comp_apply, hec, hfc]; rfl)
      = (mapCoeff1 f hf hfc).comp (mapCoeff1 e he hec) := by
  ext x
  induction x using QuotientAddGroup.induction_on with
  | _ z => rfl

end Functoriality

variable {C : Type} [Group C] [TopologicalSpace C] [DiscreteTopology C] [Finite C]
variable {V : Type} [AddCommGroup V] [TopologicalSpace V] [DiscreteTopology V] [Finite V]
  [DistribMulAction AbsGalQ2 V] [ContinuousSMul AbsGalQ2 V] [DistribMulAction C V]

/-- **Step 1 of the unramified model**: the acting group `C` is cyclic, generated by
`c tameSigma`.  Faithfulness (`hfaith`) upgrades the trivial *action* `hunram` to the trivial
*element* `c tameTau = 1`, then tame topological generation (`SectionThree.gen_ttame_quotient`)
collapses the two generators to one.  (Verbatim the `hgen` step of `prop_6_9_unramified`.) -/
theorem c_cyclic (c : ContinuousMonoidHom Ttame C) (hc : Function.Surjective ‚áëc)
    (hfaith : ‚àÄ h : C, (‚àÄ v : V, h ‚Ä¢ v = v) ‚Üí h = 1)
    (hunram : ‚àÄ v : V, c tameTau ‚Ä¢ v = v) :
    ‚àÄ x : C, x ‚àà Subgroup.zpowers (c tameSigma) := by
  have htautriv : c tameTau = 1 := hfaith (c tameTau) hunram
  have hcl : Subgroup.closure {c tameSigma, c tameTau} = ‚ä§ :=
    SectionThree.gen_ttame_quotient c.toMonoidHom c.continuous_toFun hc
  rw [htautriv] at hcl
  have hz : Subgroup.closure ({c tameSigma, 1} : Set C) = Subgroup.zpowers (c tameSigma) := by
    rw [Subgroup.zpowers_eq_closure]
    apply le_antisymm
    ¬∑ rw [Subgroup.closure_le]
      intro y hy
      rcases hy with rfl | rfl
      ¬∑ exact Subgroup.subset_closure (Set.mem_singleton _)
      ¬∑ exact one_mem _
    ¬∑ exact Subgroup.closure_mono (Set.singleton_subset_iff.mpr (Set.mem_insert _ _))
  rw [hz] at hcl
  intro x; rw [hcl]; trivial

/-- Commutativity of a cyclic `C` (generated by `t`): every element is a power of `t`. -/
theorem comm_of_cyclic (t : C) (hcyc : ‚àÄ x : C, x ‚àà Subgroup.zpowers t) (a b : C) :
    a * b = b * a := by
  obtain ‚ü®i, hi‚ü© := Subgroup.mem_zpowers_iff.mp (hcyc a)
  obtain ‚ü®j, hj‚ü© := Subgroup.mem_zpowers_iff.mp (hcyc b)
  rw [‚Üê hi, ‚Üê hj, ‚Üê zpow_add, ‚Üê zpow_add, add_comm]

/-- **The coefficient endomorphism of `H¬π(G_‚Ñö‚ÇÇ, V)` attached to `c : C`** (for a `œÅ`-factored
action with `C` commutative): `c ‚Ä¢ ¬∑` is a `G_‚Ñö‚ÇÇ`-equivariant additive endo of `V` ‚Äî
equivariance is commutativity of `C` with the `œÅ`-factored action ‚Äî so it acts on `H¬π` via
`mapCoeff1`. -/
noncomputable def cCoeff (œÅ : ContinuousMonoidHom AbsGalQ2 C)
    (hœÅ : ‚àÄ (g : AbsGalQ2) (v : V), g ‚Ä¢ v = œÅ g ‚Ä¢ v)
    (hCcomm : ‚àÄ a b : C, a * b = b * a) (c : C) :
    H1 AbsGalQ2 V ‚Üí+ H1 AbsGalQ2 V :=
  mapCoeff1 (DistribMulAction.toAddMonoidHom V c) continuous_of_discreteTopology
    (fun g v => by
      show c ‚Ä¢ (g ‚Ä¢ v) = g ‚Ä¢ (c ‚Ä¢ v)
      rw [hœÅ g v, hœÅ g (c ‚Ä¢ v), ‚Üê mul_smul, ‚Üê mul_smul, hCcomm])

/-- **The coefficient action of a commutative `C` on `H¬π(G_‚Ñö‚ÇÇ, V)`** (brick toward
`arf(Q0loc)=1`): the `DistribMulAction` axioms for `cCoeff` descend from `mapCoeff1`
functoriality (`mapCoeff1_id`/`mapCoeff1_comp`). -/
noncomputable def cActionH1 (œÅ : ContinuousMonoidHom AbsGalQ2 C)
    (hœÅ : ‚àÄ (g : AbsGalQ2) (v : V), g ‚Ä¢ v = œÅ g ‚Ä¢ v)
    (hCcomm : ‚àÄ a b : C, a * b = b * a) : DistribMulAction C (H1 AbsGalQ2 V) where
  smul c := cCoeff œÅ hœÅ hCcomm c
  one_smul x := by
    induction x using QuotientAddGroup.induction_on with
    | _ z =>
      show mapCoeff1 (DistribMulAction.toAddMonoidHom V (1 : C)) _ _ (H1mk AbsGalQ2 V z)
        = H1mk AbsGalQ2 V z
      rw [mapCoeff1_H1mk]
      congr 1
      exact Subtype.ext (funext fun g => one_smul _ _)
  mul_smul a b x := by
    induction x using QuotientAddGroup.induction_on with
    | _ z =>
      show mapCoeff1 (DistribMulAction.toAddMonoidHom V (a * b)) _ _ (H1mk AbsGalQ2 V z)
        = mapCoeff1 (DistribMulAction.toAddMonoidHom V a) _ _
            (mapCoeff1 (DistribMulAction.toAddMonoidHom V b) _ _ (H1mk AbsGalQ2 V z))
      rw [mapCoeff1_H1mk, mapCoeff1_H1mk, mapCoeff1_H1mk]
      congr 1
      exact Subtype.ext (funext fun g => mul_smul a b _)
  smul_zero c := map_zero _
  smul_add c x y := map_add _ _ _

/-- **The Schur transfer (brick (c))**: for a cyclic `C = ‚ü®T‚ü©` acting faithfully and simply on a
finite nontrivial `V`, the coefficient action `cCoeff` on `H¬π(G_‚Ñö‚ÇÇ, V)` is again *faithful* and
*simple*, provided `#H¬π = #V`.

Route: `F := ùîΩ‚ÇÇ‚ü®œÉ‚ü© ‚äÜ End(V)` (`œÉ` = the `T`-action) is a finite domain ‚Äî kernels of its nonzero
elements are `C`-stable, so trivial by simplicity, and injective ‚üπ bijective on finite `V` ‚Äî
hence a *field* by little Wedderburn (`Finite.isDomain_to_isField`; no commutativity needed as
input).  The orbit map `F ‚Üí V`, `f ‚Ü¶ f v‚ÇÄ` at any `v‚ÇÄ ‚âÝ 0` is injective with `C`-stable range,
so bijective by simplicity: `#F = #V`.  `mapCoeff1` transfers `F` multiplicatively/additively to
`End(H¬π)`, where units of `F` stay pointwise-invertible; the orbit map `F ‚Üí H¬π` at any
`0 ‚âÝ x‚ÇÄ ‚àà S` for a `C`-stable `S` is injective with range inside `S`, so
`#S ‚â• #F = #V = #H¬π` forces `S = ‚ä§`. -/
theorem cCoeff_faithful_and_simple (œÅ : ContinuousMonoidHom AbsGalQ2 C)
    (hœÅ : ‚àÄ (g : AbsGalQ2) (v : V), g ‚Ä¢ v = œÅ g ‚Ä¢ v)
    (hCcomm : ‚àÄ a b : C, a * b = b * a)
    (T : C) (hcyc : ‚àÄ x : C, x ‚àà Subgroup.zpowers T)
    (hfaith : ‚àÄ h : C, (‚àÄ v : V, h ‚Ä¢ v = v) ‚Üí h = 1)
    (hsimple : ‚àÄ W : AddSubgroup V, (‚àÄ (h : C), ‚àÄ w ‚àà W, h ‚Ä¢ w ‚àà W) ‚Üí W = ‚ä• ‚à® W = ‚ä§)
    (hVnt : Nontrivial V)
    (hcardeq : Nat.card (H1 AbsGalQ2 V) = Nat.card V) :
    (‚àÄ c : C, (‚àÄ x : H1 AbsGalQ2 V, cCoeff œÅ hœÅ hCcomm c x = x) ‚Üí c = 1) ‚àß
    Nontrivial (H1 AbsGalQ2 V) ‚àß
    ‚àÄ S : AddSubgroup (H1 AbsGalQ2 V),
      (‚àÄ (c : C), ‚àÄ x ‚àà S, cCoeff œÅ hœÅ hCcomm c x ‚àà S) ‚Üí S = ‚ä• ‚à® S = ‚ä§ := by
  classical
  haveI : Finite (AddMonoid.End V) :=
    Finite.of_injective (fun f => (f : V ‚Üí V)) DFunLike.coe_injective
  haveI : Finite (H1 AbsGalQ2 V) := Foundations.finite_H1 V
  haveI hH1nt : Nontrivial (H1 AbsGalQ2 V) := by
    rw [‚Üê Finite.one_lt_card_iff_nontrivial, hcardeq, Finite.one_lt_card_iff_nontrivial]
    exact hVnt
  set œÉ : AddMonoid.End V := DistribMulAction.toAddMonoidEnd C V T with hœÉdef
  set F : Subring (AddMonoid.End V) := Subring.closure {œÉ} with hFdef
  -- powers of `T` exhaust `C`
  have hfin : IsOfFinOrder T :=
    isOfFinOrder_iff_pow_eq_one.mpr ‚ü®orderOf T, orderOf_pos T, pow_orderOf_eq_one T‚ü©
  have hnatpow : ‚àÄ g : C, ‚àÉ k : ‚Ñï, T ^ k = g := fun g =>
    (Submonoid.mem_powers_iff g T).mp (hfin.mem_powers_iff_mem_zpowers.mpr (hcyc g))
  -- the action of any `c : C`, as an element of `End V`, is a power of `œÉ`
  have hactapp : ‚àÄ (c : C) (v : V), DistribMulAction.toAddMonoidEnd C V c v = c ‚Ä¢ v :=
    fun c v => rfl
  have hactpow : ‚àÄ c : C, ‚àÉ k : ‚Ñï, DistribMulAction.toAddMonoidEnd C V c = œÉ ^ k := by
    intro c
    obtain ‚ü®k, hk‚ü© := hnatpow c
    exact ‚ü®k, by rw [‚Üê hk, map_pow]‚ü©
  have hmemAct : ‚àÄ c : C, DistribMulAction.toAddMonoidEnd C V c ‚àà F := by
    intro c
    obtain ‚ü®k, hk‚ü© := hactpow c
    rw [hk]
    exact pow_mem (Subring.subset_closure (Set.mem_singleton œÉ)) k
  -- every element of `F` commutes with `œÉ`
  have hcommœÉ : ‚àÄ f ‚àà F, f * œÉ = œÉ * f := by
    intro f hf
    induction hf using Subring.closure_induction with
    | mem x hx => rw [Set.mem_singleton_iff.mp hx]
    | zero => rw [zero_mul, mul_zero]
    | one => rw [one_mul, mul_one]
    | add x y hx hy ihx ihy => rw [add_mul, mul_add, ihx, ihy]
    | neg x hx ih => rw [neg_mul, mul_neg, ih]
    | mul x y hx hy ihx ihy => rw [mul_assoc, ihy, ‚Üê mul_assoc, ihx, mul_assoc]
  -- `C`-equivariance of every `f ‚àà F`
  have hCequivF : ‚àÄ f ‚àà F, ‚àÄ (c : C) (v : V), f (c ‚Ä¢ v) = c ‚Ä¢ f v := by
    intro f hf c v
    obtain ‚ü®k, hk‚ü© := hactpow c
    have hcomm : f * œÉ ^ k = œÉ ^ k * f := (Commute.pow_right (hcommœÉ f hf) k)
    have h1 : ‚àÄ w : V, c ‚Ä¢ w = (œÉ ^ k) w := fun w => by rw [‚Üê hk]; rfl
    calc f (c ‚Ä¢ v) = f ((œÉ ^ k) v) := by rw [h1]
      _ = (f * œÉ ^ k) v := rfl
      _ = (œÉ ^ k * f) v := by rw [hcomm]
      _ = (œÉ ^ k) (f v) := rfl
      _ = c ‚Ä¢ f v := (h1 (f v)).symm
  -- **Schur**: nonzero elements of `F` are bijective on `V`
  have hbij : ‚àÄ f ‚àà F, f ‚âÝ 0 ‚Üí Function.Bijective f := by
    intro f hf hne
    let K : AddSubgroup V :=
      { carrier := {v | f v = 0}
        zero_mem' := map_zero f
        add_mem' := fun {a b} ha hb => by
          show f (a + b) = 0
          rw [map_add, show f a = 0 from ha, show f b = 0 from hb, add_zero]
        neg_mem' := fun {a} ha => by
          show f (-a) = 0
          rw [map_neg, show f a = 0 from ha, neg_zero] }
    have hKstab : ‚àÄ (c : C), ‚àÄ v ‚àà K, c ‚Ä¢ v ‚àà K := by
      intro c v hv
      show f (c ‚Ä¢ v) = 0
      rw [hCequivF f hf c v, show f v = 0 from hv, smul_zero]
    rcases hsimple K hKstab with hb | ht
    ¬∑ refine Finite.injective_iff_bijective.mp (fun a b hab => ?_)
      have hmem : a - b ‚àà K := by
        show f (a - b) = 0
        rw [map_sub, hab, sub_self]
      rw [hb, AddSubgroup.mem_bot] at hmem
      exact sub_eq_zero.mp hmem
    ¬∑ refine absurd (AddMonoidHom.ext fun v => ?_) hne
      have hmem : v ‚àà K := ht ‚ñ∏ AddSubgroup.mem_top v
      exact hmem
  -- `F` is a finite field (little Wedderburn ‚Äî no commutativity input needed)
  haveI : Nontrivial F := by
    refine ‚ü®0, 1, fun h => ?_‚ü©
    obtain ‚ü®v, hv‚ü© := exists_ne (0 : V)
    apply hv
    have h2 : ((0 : F) : AddMonoid.End V) v = ((1 : F) : AddMonoid.End V) v := by rw [h]
    simpa using h2.symm
  haveI : NoZeroDivisors F := by
    refine ‚ü®fun {a b} hab => ?_‚ü©
    by_contra hcon
    push_neg at hcon
    obtain ‚ü®ha, hb‚ü© := hcon
    have hbbij : Function.Bijective (b : AddMonoid.End V) :=
      hbij b.1 b.2 (fun h0 => hb (Subtype.ext h0))
    have habij : Function.Bijective (a : AddMonoid.End V) :=
      hbij a.1 a.2 (fun h0 => ha (Subtype.ext h0))
    obtain ‚ü®v, hv‚ü© := exists_ne (0 : V)
    have h0 : (a : AddMonoid.End V) ((b : AddMonoid.End V) v) = 0 := by
      have := congrArg (fun g : F => (g : AddMonoid.End V) v) hab
      simpa using this
    have hbv : (b : AddMonoid.End V) v = 0 :=
      habij.1 (by rw [h0, map_zero])
    exact hv (hbbij.1 (by rw [hbv, map_zero]))
  haveI : IsDomain F := NoZeroDivisors.to_isDomain F
  have hfield : IsField F := Finite.isDomain_to_isField F
  -- the orbit bijection `F ‚âÉ V` at any `v‚ÇÄ ‚âÝ 0`
  obtain ‚ü®v‚ÇÄ, hv‚ÇÄ‚ü© := exists_ne (0 : V)
  have hŒ∏inj : Function.Injective (fun f : F => (f : AddMonoid.End V) v‚ÇÄ) := by
    intro f g hfg
    have hfg' : (f : AddMonoid.End V) v‚ÇÄ = (g : AddMonoid.End V) v‚ÇÄ := hfg
    by_contra hne
    have hd0 : ((f - g : F) : AddMonoid.End V) ‚âÝ 0 :=
      fun h0 => hne (sub_eq_zero.mp (Subtype.ext h0))
    have hdbij := hbij _ (f - g).2 hd0
    apply hv‚ÇÄ
    apply hdbij.1
    rw [map_zero]
    show (f : AddMonoid.End V) v‚ÇÄ - (g : AddMonoid.End V) v‚ÇÄ = 0
    rw [hfg', sub_self]
  have hŒ∏surj : Function.Surjective (fun f : F => (f : AddMonoid.End V) v‚ÇÄ) := by
    let R0 : AddSubgroup V :=
      { carrier := Set.range (fun f : F => (f : AddMonoid.End V) v‚ÇÄ)
        zero_mem' := ‚ü®0, rfl‚ü©
        add_mem' := by
          rintro x y ‚ü®fx, hfx‚ü© ‚ü®fy, hfy‚ü©
          have hfx' : (fx : AddMonoid.End V) v‚ÇÄ = x := hfx
          have hfy' : (fy : AddMonoid.End V) v‚ÇÄ = y := hfy
          refine ‚ü®fx + fy, ?_‚ü©
          show (fx : AddMonoid.End V) v‚ÇÄ + (fy : AddMonoid.End V) v‚ÇÄ = x + y
          rw [hfx', hfy']
        neg_mem' := by
          rintro x ‚ü®fx, hfx‚ü©
          have hfx' : (fx : AddMonoid.End V) v‚ÇÄ = x := hfx
          refine ‚ü®-fx, ?_‚ü©
          show -((fx : AddMonoid.End V) v‚ÇÄ) = -x
          rw [hfx'] }
    have hRstab : ‚àÄ (c : C), ‚àÄ v ‚àà R0, c ‚Ä¢ v ‚àà R0 := by
      rintro c v ‚ü®f, hf‚ü©
      have hf' : (f : AddMonoid.End V) v‚ÇÄ = v := hf
      refine ‚ü®‚ü®DistribMulAction.toAddMonoidEnd C V c, hmemAct c‚ü© * f, ?_‚ü©
      show DistribMulAction.toAddMonoidEnd C V c ((f : AddMonoid.End V) v‚ÇÄ) = c ‚Ä¢ v
      rw [hf', hactapp]
    rcases hsimple R0 hRstab with hb | ht
    ¬∑ exfalso
      have h1 : v‚ÇÄ ‚àà R0 := ‚ü®1, rfl‚ü©
      rw [hb, AddSubgroup.mem_bot] at h1
      exact hv‚ÇÄ h1
    ¬∑ intro v
      exact (ht ‚ñ∏ AddSubgroup.mem_top v : v ‚àà R0)
  have hFcard : Nat.card F = Nat.card V :=
    Nat.card_eq_of_bijective _ ‚ü®hŒ∏inj, hŒ∏surj‚ü©
  -- === the transfer `Œ¶ : F ‚Üí End(H¬π)` via `mapCoeff1` ===
  have hGequivF : ‚àÄ f (hf : f ‚àà F), ‚àÄ (Œ≥ : AbsGalQ2) (v : V), f (Œ≥ ‚Ä¢ v) = Œ≥ ‚Ä¢ f v := by
    intro f hf Œ≥ v
    rw [hœÅ Œ≥ v, hœÅ Œ≥ (f v)]
    exact hCequivF f hf (œÅ Œ≥) v
  set Œ¶ : F ‚Üí (H1 AbsGalQ2 V ‚Üí+ H1 AbsGalQ2 V) := fun f =>
    mapCoeff1 (f : AddMonoid.End V) continuous_of_discreteTopology (hGequivF f.1 f.2)
    with hŒ¶def
  have hŒ¶mul : ‚àÄ (f g : F) (x : H1 AbsGalQ2 V), Œ¶ (f * g) x = Œ¶ f (Œ¶ g x) := by
    intro f g x
    induction x using QuotientAddGroup.induction_on with
    | _ z => rfl
  have hŒ¶add : ‚àÄ (f g : F) (x : H1 AbsGalQ2 V), Œ¶ (f + g) x = Œ¶ f x + Œ¶ g x := by
    intro f g x
    induction x using QuotientAddGroup.induction_on with
    | _ z => rfl
  have hŒ¶one : ‚àÄ x : H1 AbsGalQ2 V, Œ¶ 1 x = x := by
    intro x
    induction x using QuotientAddGroup.induction_on with
    | _ z => rfl
  have hŒ¶zero : ‚àÄ x : H1 AbsGalQ2 V, Œ¶ 0 x = 0 := by
    intro x
    induction x using QuotientAddGroup.induction_on with
    | _ z => rfl
  have hŒ¶sub : ‚àÄ (f g : F) (x : H1 AbsGalQ2 V), Œ¶ (f - g) x = Œ¶ f x - Œ¶ g x := by
    intro f g x
    have h1 := hŒ¶add (f - g) g x
    rw [sub_add_cancel] at h1
    rw [eq_sub_iff_add_eq, ‚Üê h1]
  -- `cCoeff` is `Œ¶` at the action element
  have hcCoeffŒ¶ : ‚àÄ (c : C) (x : H1 AbsGalQ2 V),
      cCoeff œÅ hœÅ hCcomm c x = Œ¶ ‚ü®DistribMulAction.toAddMonoidEnd C V c, hmemAct c‚ü© x := by
    intro c x
    induction x using QuotientAddGroup.induction_on with
    | _ z => rfl
  -- === (c1) faithfulness on `H¬π` ===
  have hfaithH1 : ‚àÄ c : C, (‚àÄ x : H1 AbsGalQ2 V, cCoeff œÅ hœÅ hCcomm c x = x) ‚Üí c = 1 := by
    intro c hcx
    set u : F := ‚ü®DistribMulAction.toAddMonoidEnd C V c, hmemAct c‚ü© - 1 with hudef
    by_cases hu : u = 0
    ¬∑ -- `c` acts trivially on `V`
      apply hfaith c
      intro v
      have h1 : (u : AddMonoid.End V) v = ((0 : F) : AddMonoid.End V) v := by rw [hu]
      have h2 : c ‚Ä¢ v - v = 0 := by
        have h3 : (u : AddMonoid.End V) v = c ‚Ä¢ v - v := rfl
        rw [‚Üê h3, h1]
        rfl
      exact sub_eq_zero.mp h2
    ¬∑ exfalso
      obtain ‚ü®w, hw‚ü© := hfield.mul_inv_cancel hu
      have hŒ¶u : ‚àÄ x : H1 AbsGalQ2 V, Œ¶ u x = 0 := by
        intro x
        rw [hudef, hŒ¶sub, ‚Üê hcCoeffŒ¶, hcx x, hŒ¶one, sub_self]
      obtain ‚ü®x, hx‚ü© := exists_ne (0 : H1 AbsGalQ2 V)
      apply hx
      have hcm : u * w = w * u := (hfield.mul_comm u w)
      calc x = Œ¶ 1 x := (hŒ¶one x).symm
        _ = Œ¶ (w * u) x := by rw [‚Üê hw, hcm]
        _ = Œ¶ w (Œ¶ u x) := hŒ¶mul w u x
        _ = Œ¶ w 0 := by rw [hŒ¶u]
        _ = 0 := map_zero _
  refine ‚ü®hfaithH1, hH1nt, ?_‚ü©
  -- === (c2) simplicity of `H¬π` ===
  intro S hS
  by_cases hSbot : S = ‚ä•
  ¬∑ exact Or.inl hSbot
  refine Or.inr ?_
  have hx‚ÇÄ : ‚àÉ x ‚àà S, x ‚âÝ 0 := by
    by_contra hcon
    push_neg at hcon
    exact hSbot ((AddSubgroup.eq_bot_iff_forall S).mpr hcon)
  obtain ‚ü®x‚ÇÄ, hx‚ÇÄS, hx‚ÇÄne‚ü© := hx‚ÇÄ
  -- `S` is stable under all of `Œ¶(F)`
  have hFS : ‚àÄ (f : AddMonoid.End V) (hf : f ‚àà F), ‚àÄ x ‚àà S, Œ¶ ‚ü®f, hf‚ü© x ‚àà S := by
    intro f hf
    induction hf using Subring.closure_induction with
    | mem y hy =>
      intro x hx
      have hyœÉ := Set.mem_singleton_iff.mp hy
      subst hyœÉ
      have h1 : Œ¶ ‚ü®œÉ, Subring.subset_closure (Set.mem_singleton œÉ)‚ü© x
          = cCoeff œÅ hœÅ hCcomm T x := (hcCoeffŒ¶ T x).symm
      rw [h1]
      exact hS T x hx
    | zero =>
      intro x hx
      show Œ¶ (0 : F) x ‚àà S
      rw [hŒ¶zero]
      exact S.zero_mem
    | one =>
      intro x hx
      show Œ¶ (1 : F) x ‚àà S
      rw [hŒ¶one]
      exact hx
    | add y z hy hz ihy ihz =>
      intro x hx
      have h1 : Œ¶ (‚ü®y, hy‚ü© + ‚ü®z, hz‚ü© : F) x = Œ¶ ‚ü®y, hy‚ü© x + Œ¶ ‚ü®z, hz‚ü© x := hŒ¶add _ _ x
      exact h1 ‚ñ∏ S.add_mem (ihy x hx) (ihz x hx)
    | neg y hy ih =>
      intro x hx
      have h1 : Œ¶ (-‚ü®y, hy‚ü© : F) x = -Œ¶ ‚ü®y, hy‚ü© x := by
        have h2 := hŒ¶sub 0 ‚ü®y, hy‚ü© x
        rw [zero_sub, hŒ¶zero, zero_sub] at h2
        exact h2
      exact h1 ‚ñ∏ S.neg_mem (ih x hx)
    | mul y z hy hz ihy ihz =>
      intro x hx
      have h1 : Œ¶ (‚ü®y, hy‚ü© * ‚ü®z, hz‚ü© : F) x = Œ¶ ‚ü®y, hy‚ü© (Œ¶ ‚ü®z, hz‚ü© x) := hŒ¶mul _ _ x
      exact h1 ‚ñ∏ ihy _ (ihz x hx)
  -- the injection `F ‚Ü™ S` at `x‚ÇÄ`
  have hŒ®inj : Function.Injective (fun f : F => Œ¶ f x‚ÇÄ) := by
    intro f g hfg
    have hfg' : Œ¶ f x‚ÇÄ = Œ¶ g x‚ÇÄ := hfg
    by_contra hne
    have hd : f - g ‚âÝ 0 := sub_ne_zero.mpr hne
    obtain ‚ü®w, hw‚ü© := hfield.mul_inv_cancel hd
    apply hx‚ÇÄne
    have hcm : (f - g) * w = w * (f - g) := hfield.mul_comm _ _
    calc x‚ÇÄ = Œ¶ 1 x‚ÇÄ := (hŒ¶one x‚ÇÄ).symm
      _ = Œ¶ (w * (f - g)) x‚ÇÄ := by rw [‚Üê hw, hcm]
      _ = Œ¶ w (Œ¶ (f - g) x‚ÇÄ) := hŒ¶mul _ _ x‚ÇÄ
      _ = Œ¶ w 0 := by rw [hŒ¶sub, hfg', sub_self]
      _ = 0 := map_zero _
  have hle : Nat.card F ‚â§ Nat.card S := by
    refine Nat.card_le_card_of_injective
      (fun f : F => (‚ü®Œ¶ f x‚ÇÄ, hFS f.1 f.2 x‚ÇÄ hx‚ÇÄS‚ü© : S)) (fun a b hab => ?_)
    exact hŒ®inj (congrArg Subtype.val hab)
  have hcards : Nat.card S = Nat.card (H1 AbsGalQ2 V) := by
    refine le_antisymm (AddSubgroup.card_le_card_addGroup S) ?_
    calc Nat.card (H1 AbsGalQ2 V) = Nat.card V := hcardeq
      _ = Nat.card F := hFcard.symm
      _ ‚â§ Nat.card S := hle
  exact (AddSubgroup.card_eq_iff_eq_top S).mp hcards

/-- **Proposition 6.18, eq. (115), unramified case**: negative Gauss sign,
`#(Q‚Å∞_loc)‚Åª¬π(0) = 2^{2m‚àí1} ‚àí 2^{m‚àí1}`.

Proved via the Hermitian-line model (see the file docstring): identify `V` with `ùîΩ_{2^{2m}}`,
transport `Q‚Å∞_loc` to a norm-one-invariant nonsingular form, and count zeros with
`card_normOne_invariant_form_zero`.  [P-14 statement; proof P-15f3, Ax: B6, B7.]

**Statement amended (P-15f, flag for P-20)**: added `hc : Function.Surjective ‚áëc` (as in
`prop_6_18_ramified`). -/
theorem prop_6_18_unramified (D : TateDuality 2) (B : BoundaryMaps)
    (c : ContinuousMonoidHom Ttame C)
    (hc : Function.Surjective ‚áëc)
    (œÅ : ContinuousMonoidHom AbsGalQ2 C) (hfac : ‚àÄ g, œÅ g = c (B.tameF g))
    (hœÅ : ‚àÄ (g : AbsGalQ2) (v : V), g ‚Ä¢ v = œÅ g ‚Ä¢ v)
    (hfaith : ‚àÄ h : C, (‚àÄ v : V, h ‚Ä¢ v = v) ‚Üí h = 1)
    (hsimple : ‚àÄ W : AddSubgroup V, (‚àÄ (h : C), ‚àÄ w ‚àà W, h ‚Ä¢ w ‚àà W) ‚Üí W = ‚ä• ‚à® W = ‚ä§)
    (hV : ‚àÉ v : V, v ‚âÝ 0)
    (hunram : ‚àÄ v : V, c tameTau ‚Ä¢ v = v)
    (q : V ‚Üí ZMod 2) (hq : IsQuadraticFp2 q) (hns : Nonsingular q) (hinv : IsInvariant C q)
    (dat : FactorSet C V) (hdat : IsEquivariantFactorSet q dat)
    (m : ‚Ñï) (hm : 1 ‚â§ m) (hcard : Nat.card V = 2 ^ (2 * m)) :
    Nat.card {x : H1 AbsGalQ2 V // Q0loc D dat œÅ x = 0}
      = 2 ^ (2 * m - 1) - 2 ^ (m - 1) := by
  classical
  haveI : Finite (H1 AbsGalQ2 V) := Foundations.finite_H1 V
  haveI : Fintype (H1 AbsGalQ2 V) := Fintype.ofFinite _
  have hV2 : ‚àÄ v : V, v + v = 0 := exp_two_of_simple_of_card hsimple m hm hcard
  have hqG : ‚àÄ (g : AbsGalQ2) (v : V), q (g ‚Ä¢ v) = q v := fun g v => by rw [hœÅ]; exact hinv _ v
  have hquad : IsQuadraticFp2 (Q0loc D dat œÅ (V := V)) :=
    isQuadraticFp2_Q0loc D q hq dat hdat œÅ hœÅ hqG
  have hnons : Nonsingular (Q0loc D dat œÅ (V := V)) :=
    nonsingular_Q0loc D q hq hns hV2 dat hdat œÅ hœÅ hqG
  -- the `C`-action moves some vector (else `V` is `ùîΩ‚ÇÇ`, contradicting `#V = 2^{2m}`, `m ‚â• 1`)
  have hmove : ‚àÉ (h‚ÇÄ : C) (v : V), h‚ÇÄ ‚Ä¢ v ‚âÝ v := by
    by_contra hcon
    push_neg at hcon
    obtain ‚ü®v, hv‚ü© := hV
    haveI : Fact (Nat.Prime 2) := ‚ü®Nat.prime_two‚ü©
    have hord : addOrderOf v = 2 := addOrderOf_eq_prime (by rw [two_nsmul]; exact hV2 v) hv
    have htop : AddSubgroup.zmultiples v = ‚ä§ := by
      refine (hsimple _ (fun h w hw => by rw [hcon]; exact hw)).resolve_left (fun h0 => hv ?_)
      have hmem : v ‚àà AddSubgroup.zmultiples v := AddSubgroup.mem_zmultiples v
      rw [h0, AddSubgroup.mem_bot] at hmem; exact hmem
    have hcard2 : Nat.card V = 2 := by
      have h1 : Nat.card ‚Ü•(AddSubgroup.zmultiples v) = 2 := by rw [Nat.card_zmultiples, hord]
      rwa [htop, Nat.card_congr AddSubgroup.topEquiv.toEquiv] at h1
    rw [hcard] at hcard2
    have h4 : (4 : ‚Ñï) ‚â§ 2 ^ (2 * m) :=
      calc (4 : ‚Ñï) = 2 ^ 2 := by norm_num
        _ ‚â§ 2 ^ (2 * m) := Nat.pow_le_pow_right (by norm_num) (by omega)
    omega
  obtain ‚ü®h‚ÇÄ, hmoves‚ü© := hmove
  have hœÅsurj : Function.Surjective ‚áëœÅ := by
    intro y
    obtain ‚ü®t, ht‚ü© := hc y
    obtain ‚ü®g, hg‚ü© := B.tameF_surjective t
    exact ‚ü®g, by rw [hfac, hg, ht]‚ü©
  have hcardH1 : Fintype.card (H1 AbsGalQ2 V) = 2 ^ (2 * m) := by
    rw [‚Üê Nat.card_eq_fintype_card,
      card_H1_eq_card_of_simple V D œÅ.toMonoidHom hœÅsurj hœÅ hsimple h‚ÇÄ hmoves q hq hns hinv hV2,
      hcard]
  -- **The Arf invariant is `1` (minus type)** ‚Äî via `GaussSigns.arf_eq_s_ramified` on `H¬π`:
  -- `C = ‚ü®c tameSigma‚ü©` is cyclic (`c_cyclic`), its coefficient action on `H¬π` is faithful and
  -- simple (`cCoeff_faithful_and_simple`, the Schur transfer), `H¬π ‚âÉ+ (Fin 1 ‚Üí H¬π)` trivially,
  -- and `s = 1` is odd ‚Äî so `arf (Q0loc) = 1` once `Q0loc` is `C`-invariant (brick (d), the
  -- one remaining sorry: Lemma 6.4 datum-independence through `lemma_6_14` naturality).
  have harf : arf (Q0loc D dat œÅ (V := V)) = 1 := by
    have hcyc := c_cyclic c hc hfaith hunram
    have hCcomm := comm_of_cyclic (c tameSigma) hcyc
    haveI hVnt : Nontrivial V := by
      obtain ‚ü®v, hv‚ü© := hV
      exact ‚ü®v, 0, hv‚ü©
    have hcardeq : Nat.card (H1 AbsGalQ2 V) = Nat.card V := by
      rw [Nat.card_eq_fintype_card, hcardH1, hcard]
    obtain ‚ü®hfaithH1, hntH1, hsimpleH1‚ü© :=
      cCoeff_faithful_and_simple œÅ hœÅ hCcomm (c tameSigma) hcyc hfaith hsimple hVnt hcardeq
    letI actH1 : DistribMulAction C (H1 AbsGalQ2 V) := cActionH1 œÅ hœÅ hCcomm
    -- exponent 2 on `H¬π` (descends pointwise from `V`)
    have hH12 : ‚àÄ x : H1 AbsGalQ2 V, x + x = 0 := by
      intro x
      induction x using QuotientAddGroup.induction_on with
      | _ z =>
        have hz : z + z = 0 := Subtype.ext (funext fun Œ≥ => hV2 (z.1 Œ≥))
        show (QuotientAddGroup.mk (z + z) : H1 AbsGalQ2 V) = 0
        rw [hz]
        rfl
    -- the trivial one-block decomposition
    let e : H1 AbsGalQ2 V ‚âÉ+ (Fin 1 ‚Üí H1 AbsGalQ2 V) :=
      { toFun := fun x _ => x
        invFun := fun f => f 0
        left_inv := fun x => rfl
        right_inv := fun f => funext fun j => by rw [Subsingleton.elim (0 : Fin 1) j]
        map_add' := fun x y => rfl }
    -- **brick (d): `Q0loc` is invariant under the coefficient action** (Lemma 6.4
    -- datum-independence via `lemma_6_14` naturality) ‚Äî the sole remaining obligation
    have hqinv : ‚àÄ (g : C) (x : H1 AbsGalQ2 V),
        Q0loc D dat œÅ (g ‚Ä¢ x) = Q0loc D dat œÅ x := by
      sorry
    have h := GaussSigns.arf_eq_s_ramified (G := C) (V := H1 AbsGalQ2 V) (W := H1 AbsGalQ2 V)
      (c tameSigma) hcyc hfaithH1 ‚ü®hntH1, fun S hS => hsimpleH1 S (fun g x hx => hS g x hx)‚ü©
      hH12 hH12 (Q0loc D dat œÅ) hquad hnons hqinv m 1 hm le_rfl
      (by rw [Nat.card_eq_fintype_card, hcardH1]) e (fun g v j => rfl)
    simpa using h
  simpa only [zeroCount] using
    zeroCount_of_arf_one (Q0loc D dat œÅ (V := V)) hquad hnons hm hcardH1 harf

end UnramifiedModel

