/-! ## Central double covers  (¬ß8) -/

/-- **A central double cover** of the finite group `Y` (¬ß8): a surjection whose kernel is
generated by a central element `z ‚Č† 1` of square one. -/
structure CentralCover (Y : Type) [Group Y] [Finite Y] where
  /-- The covering group. -/
  cover : Type
  [group : Group cover]
  [finite : Finite cover]
  [topo : TopologicalSpace cover]
  [disc : DiscreteTopology cover]
  /-- The covering surjection. -/
  p : cover ‚Üí* Y
  surj : Function.Surjective p
  /-- The central kernel generator. -/
  z : cover
  z_ne : z ‚Č† 1
  z_sq : z * z = 1
  central : ‚ąÄ x : cover, z * x = x * z
  ker_eq : p.ker = Subgroup.zpowers z

attribute [instance] CentralCover.group CentralCover.finite CentralCover.topo
  CentralCover.disc

namespace CentralCover

variable {Y : Type} [Group Y] [Finite Y] (C : CentralCover Y)

/-- Squares die in the kernel subgroup `‚ü®z‚ü©` (its elements have order ‚Č§ 2). -/
lemma sq_eq_one_of_mem_ker {x : C.cover} (hx : x ‚ąą C.p.ker) : x * x = 1 := by
  rw [C.ker_eq] at hx
  obtain ‚ü®n, rfl‚ü© := hx
  rw [‚Üź Commute.mul_zpow (Commute.refl C.z), C.z_sq, one_zpow]

/-- `z`-powers by `ūĚĒĹ‚āā`-exponents add (any central double cover: `z¬≤ = 1`). -/
theorem z_pow_val_add (a b : ZMod 2) :
    C.z ^ (a + b).val = C.z ^ a.val * C.z ^ b.val := by
  rcases (show ‚ąÄ x : ZMod 2, x = 0 ‚ą® x = 1 from by decide) a with rfl | rfl <;>
    rcases (show ‚ąÄ x : ZMod 2, x = 0 ‚ą® x = 1 from by decide) b with rfl | rfl
  ¬∑ show C.z ^ 0 = C.z ^ 0 * C.z ^ 0
    rw [pow_zero, one_mul]
  ¬∑ show C.z ^ 1 = C.z ^ 0 * C.z ^ 1
    rw [pow_zero, one_mul]
  ¬∑ show C.z ^ 1 = C.z ^ 1 * C.z ^ 0
    rw [pow_zero, mul_one]
  ¬∑ show C.z ^ 0 = C.z ^ 1 * C.z ^ 1
    rw [pow_zero, pow_one]
    exact C.z_sq.symm

end CentralCover

/-! ## The Lemma 8.6 datum  (radical cover) -/

/-- The multiplicative polar form of a `ūĚĒĹ‚āā`-valued square function on (a subgroup of) a
group: `B_q(m, m') = q(mm') + q(m) + q(m')`. -/
def polarMul {M : Type*} (q : M ‚Üí ZMod 2) (mul : M ‚Üí M ‚Üí M) (m m' : M) : ZMod 2 :=
  q (mul m m') + q m + q m'

/-- **The Lemma 8.6 datum**: a central double cover of `Bg` restricting to a quadratic form
on the elementary abelian normal subgroup `M`, with polar radical containing `T ‚Č§ M` and
vanishing on `T` (paper ¬ß8, setting of Lemma 8.6; `M = K/R`, `T = T‚āÄ` after ¬ß7). -/
structure RadicalCoverData (Bg : Type) [Group Bg] [Finite Bg] where
  /-- The central double cover `p : BŐÉ ‚Ü† B`. -/
  C : CentralCover Bg
  /-- The elementary abelian layer `M` (paper: `M = K/R`). -/
  M : Subgroup Bg
  hM : M.Normal
  /-- The polar radical `T` (paper: `T = T‚āÄ`). -/
  T : Subgroup Bg
  hT : T.Normal
  hTM : T ‚Č§ M
  helem : ‚ąÄ m ‚ąą M, m * m = 1
  hcomm : ‚ąÄ m ‚ąą M, ‚ąÄ m' ‚ąą M, m * m' = m' * m
  /-- The square form of the cover on `M`: `xŐÉ¬≤ = z^{q(x)}` for any lift `xŐÉ` of `x ‚ąą M`. -/
  q : ‚Ü•M ‚Üí ZMod 2
  hq : ‚ąÄ (x : C.cover) (hx : C.p x ‚ąą M), x * x = C.z ^ (q ‚ü®C.p x, hx‚ü©).val
  /-- `T` lies in the polar radical of `q`. -/
  hrad : ‚ąÄ (t : Bg) (ht : t ‚ąą T) (m : Bg) (hm : m ‚ąą M),
    polarMul q (fun a b => ‚ü®a.1 * b.1, mul_mem a.2 b.2‚ü©) ‚ü®t, hTM ht‚ü© ‚ü®m, hm‚ü© = 0
  /-- `q` vanishes on `T`. -/
  hTzero : ‚ąÄ (t : Bg) (ht : t ‚ąą T), q ‚ü®t, hTM ht‚ü© = 0

/-- The `M`-layer of a `RadicalCoverData` is normal (instance form, so that the quotient
`Bg ‚ßł D.M` carries its group structure in statement positions ‚ÄĒ the `TameQuotientData`
Lean-detail pattern). -/
instance RadicalCoverData.instNormalM {Bg : Type} [Group Bg] [Finite Bg]
    (D : RadicalCoverData Bg) : D.M.Normal := D.hM

/-- **"The radical edge is nonzero", operationally** (Lemma 8.6, descent clause): the cover
admits **no** descent to `B/T`, i.e. no normal complement to `p‚ĀĽ¬Ļ(T)` missing `z`. -/
def RadicalCoverData.NoDescent {Bg : Type} [Group Bg] [Finite Bg]
    (D : RadicalCoverData Bg) : Prop :=
  ¬¨‚ąÉ N : Subgroup D.C.cover, N.Normal ‚ąß N.map D.C.p = D.T ‚ąß D.C.z ‚ąČ N


/-! ## Unrestricted `M`-lifts and the central relation  (Lemma 8.6 count objects) -/

section HalfTorsor

variable {Bg : Type} [Group Bg] [TopologicalSpace Bg] [DiscreteTopology Bg] [Finite Bg]

/-- The unrestricted `M`-lifts of a lower map `ŌĀ : őď ‚Üí B/M`: continuous homomorphisms
`f : őď ‚Üí B` over `ŌĀ`. -/
def MLifts (D : RadicalCoverData Bg) {őď' : Type} [Group őď'] [TopologicalSpace őď']
    (ŌĀ : ContinuousMonoidHom őď' (Bg ‚ßł D.M)) : Type :=
  {f : ContinuousMonoidHom őď' Bg // ‚ąÄ ő≥ : őď', QuotientGroup.mk (f ő≥) = ŌĀ ő≥}

/-- An `M`-lift **satisfies the central relation** when it lifts through the cover. -/
def MLifts.Central (D : RadicalCoverData Bg) {őď' : Type} [Group őď'] [TopologicalSpace őď']
    {ŌĀ : ContinuousMonoidHom őď' (Bg ‚ßł D.M)}
    (f : MLifts D ŌĀ) : Prop :=
  ‚ąÉ g : ContinuousMonoidHom őď' D.C.cover, ‚ąÄ ő≥ : őď', D.C.p (g ő≥) = f.1 ő≥

end HalfTorsor

